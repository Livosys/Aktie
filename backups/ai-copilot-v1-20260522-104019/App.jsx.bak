import React, { lazy, Suspense } from 'react';
import { Routes, Route, Navigate } from 'react-router-dom';
import Navigation from './Navigation.jsx';
import LivePage from './pages/LivePage.jsx';
import StocksPage from './pages/StocksPage.jsx';
import NasdaqPage from './pages/NasdaqPage.jsx';
import CryptoPage from './pages/CryptoPage.jsx';
import AlertsPage from './pages/AlertsPage.jsx';
import { AlertProvider, HeroToastContainer } from './alertContext.jsx';

// Less-visited pages — lazy-loaded to keep initial bundle small
const HistoryPage       = lazy(() => import('./pages/HistoryPage.jsx'));
const ReplayPage        = lazy(() => import('./pages/ReplayPage.jsx'));
const MachinePage       = lazy(() => import('./pages/MachinePage.jsx'));
const MissedBreakoutsPage = lazy(() => import('./pages/MissedBreakoutsPage.jsx'));
const WavePage          = lazy(() => import('./pages/WavePage.jsx'));
const ReviewChartPage   = lazy(() => import('./pages/ReviewChartPage.jsx'));
const SystemHealthPage  = lazy(() => import('./pages/SystemHealthPage.jsx'));

export default function App() {
  return (
    <AlertProvider>
      <Navigation />
      <HeroToastContainer />
      <div className="page-wrap">
        <Suspense fallback={<div className="page-loading">Laddar...</div>}>
          <Routes>
            {/* Default → Live */}
            <Route path="/"              element={<Navigate to="/live" replace />} />

            {/* New simplified nav targets */}
            <Route path="/live"          element={<LivePage />} />
            <Route path="/intelligence"  element={<Navigate to="/machine" replace />} />
            <Route path="/health"        element={<Navigate to="/system-health" replace />} />
            <Route path="/alerts"        element={<AlertsPage />} />

            {/* All original routes — unchanged */}
            <Route path="/aktier"            element={<StocksPage />} />
            <Route path="/nasdaq"            element={<NasdaqPage />} />
            <Route path="/krypto"            element={<CryptoPage />} />
            <Route path="/historik"          element={<HistoryPage />} />
            <Route path="/replay"            element={<ReplayPage />} />
            <Route path="/machine"           element={<MachinePage />} />
            <Route path="/missed-breakouts"  element={<MissedBreakoutsPage />} />
            <Route path="/wave"              element={<WavePage />} />
            <Route path="/review-chart"      element={<ReviewChartPage />} />
            <Route path="/system-health"     element={<SystemHealthPage />} />
          </Routes>
        </Suspense>
      </div>
      <div className="footer">
        2M Scanner v2 · Live · Intelligens · Hälsa · Ingen handel utförs automatiskt
      </div>
    </AlertProvider>
  );
}
