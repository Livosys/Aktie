function buildWaveResponse(results, label) {
  const withWave = results.filter((r) => r.waveContext);
  return {
    ok: true,
    group: label,
    count: withWave.length,
    results: withWave.map((r) => ({
      symbol: r.symbol,
      price: r.price,
      lastUpdate: r.lastUpdate,
      waveContext: r.waveContext,
    })),
  };
}

