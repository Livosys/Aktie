*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* Prevent double-tap zoom on interactive elements */
button, a, [role="button"] { touch-action: manipulation; }

:root {
  color-scheme: dark;
  --bg: #090b10;
  --surface: #111520;
  --surface2: #161b2a;
  --surface3: #1c2235;
  --border: #1e2438;
  --border2: #26304a;
  --text: #dde3f2;
  --muted: #57637e;
  --muted2: #3a4260;
  --yellow: #f5c518; --yellow-dim: rgba(245,197,24,0.12); --yellow-border: #3a2e00;
  --green: #22c55e;  --green-dim:  rgba(34,197,94,0.12);  --green-border:  #003a18;
  --red: #ef4444;    --red-dim:    rgba(239,68,68,0.12);   --red-border:    #3a0000;
  --blue: #3b82f6;   --blue-dim:   rgba(59,130,246,0.12);  --blue-border:   #002a5a;
  --orange: #f97316; --orange-dim: rgba(249,115,22,0.12);  --orange-border: #3a1600;
  --purple: #a855f7; --purple-dim: rgba(168,85,247,0.12);  --purple-border: #28064a;
  /* Legacy aliases used by older components */
  --yellow-bg: #2a2200;
  --green-bg: #002a12;
  --red-bg: #2a0000;
  --gray: #57637e;
  --gray-bg: #1a1c24;
  --purple-bg: #1e0a30;
  --blue-bg: #001a3a;
  --orange-bg: #2a1200;
  --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
  --mono: 'Consolas', 'Courier New', monospace;
  --r: 10px; --r-sm: 6px; --r-lg: 14px;
  /* Semantic aliases */
  --card-bg: var(--surface2);
  --text-muted: var(--muted);
}

:root[data-theme="light"] {
  color-scheme: light;
  --bg: #f4f7fb;
  --surface: #ffffff;
  --surface2: #eef3f8;
  --surface3: #e4ebf4;
  --border: #d6deea;
  --border2: #c5cfdd;
  --text: #142033;
  --muted: #5e6b7f;
  --muted2: #8591a3;
  --yellow-dim: rgba(245,197,24,0.18); --yellow-border: #e5b800;
  --green-dim: rgba(34,197,94,0.14); --green-border: #9ee6b9;
  --red-dim: rgba(239,68,68,0.12); --red-border: #f3a1a1;
  --blue-dim: rgba(59,130,246,0.12); --blue-border: #9fc3fb;
  --orange-dim: rgba(249,115,22,0.13); --orange-border: #f3b37d;
  --purple-dim: rgba(168,85,247,0.12); --purple-border: #c8a2f2;
  --yellow-bg: #fff6c7;
  --green-bg: #dcfce7;
  --red-bg: #fee2e2;
  --gray-bg: #edf2f7;
  --purple-bg: #f3e8ff;
  --blue-bg: #dbeafe;
  --orange-bg: #ffedd5;
}

html { scroll-padding-top: 68px; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
}

#root { margin: 0; padding: 0; }
.page-wrap { max-width: 1280px; margin: 0 auto; padding: 28px 24px 56px; }

/* ── Navigation ──────────────────────────────────────────────────────────────── */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  height: 52px;
  gap: 16px;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 800;
  font-size: 0.95rem;
  letter-spacing: -0.01em;
  color: var(--text);
  text-decoration: none;
  white-space: nowrap;
}
.nav-brand-icon { font-size: 1.1rem; }

.nav-links {
  display: flex;
  align-items: stretch;
  height: 100%;
  gap: 2px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 16px;
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}

.theme-toggle {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid var(--border2);
  background: var(--surface2);
  color: var(--text);
  border-radius: 999px;
  padding: 0 12px;
  height: 32px;
  margin: auto 0 auto 6px;
  font: inherit;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
}
.theme-toggle:hover {
  background: var(--surface3);
  border-color: var(--muted2);
}

.nav-stocks:hover  { color: var(--blue); }
.nav-nasdaq:hover  { color: var(--yellow); }
.nav-crypto:hover  { color: var(--orange); }
.nav-history:hover { color: var(--purple); }
.nav-replay:hover  { color: var(--green); }
.nav-stocks.active  { color: var(--blue);   border-bottom-color: var(--blue); }
.nav-nasdaq.active  { color: var(--yellow); border-bottom-color: var(--yellow); }
.nav-crypto.active  { color: var(--orange); border-bottom-color: var(--orange); }
.nav-history.active { color: var(--purple); border-bottom-color: var(--purple); }
.nav-replay.active  { color: var(--green);  border-bottom-color: var(--green); }

/* ── Footer ──────────────────────────────────────────────────────────────────── */
.footer {
  text-align: center;
  color: var(--muted);
  font-size: 11px;
  padding: 16px 0 24px;
  border-top: 1px solid var(--border);
  margin-top: 8px;
}

/* ── Alert button ────────────────────────────────────────────────────────────── */
.btn-alert {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  background: var(--surface2);
  color: var(--muted);
  font-size: 11.5px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.btn-alert:hover {
  border-color: var(--muted);
  color: var(--text);
}
.btn-alert-active {
  border-color: var(--green);
  color: var(--green);
  background: var(--green-dim);
}
.btn-alert-active:hover {
  border-color: var(--red);
  color: var(--red);
  background: var(--red-dim);
}
.btn-alert-denied {
  border-color: #5a3a00;
  color: #f59e0b;
}
.btn-alert-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: alert-pulse 1.4s ease-in-out infinite;
}
@keyframes alert-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}

/* ── Buttons ─────────────────────────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: var(--r-sm);
  border: 1px solid var(--border2);
  background: var(--surface2);
  color: var(--text);
  font-size: 11px;
  font-family: var(--font);
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
  text-decoration: none;
}
.btn:hover { background: var(--surface3); border-color: var(--muted2); }
.btn-tv { border-color: var(--blue-border); color: var(--blue); }
.btn-tv:hover { background: var(--blue-dim); }
.btn-copy:active { background: var(--green-dim); border-color: var(--green-border); color: var(--green); }

/* ── Badges ──────────────────────────────────────────────────────────────────── */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: var(--r-sm);
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.04em;
  white-space: nowrap;
}
.badge-yellow { background: var(--yellow-dim); color: var(--yellow); border: 1px solid var(--yellow-border); }
.badge-green  { background: var(--green-dim);  color: var(--green);  border: 1px solid var(--green-border); }
.badge-red    { background: var(--red-dim);    color: var(--red);    border: 1px solid var(--red-border); }
.badge-gray   { background: var(--surface2);   color: var(--muted);  border: 1px solid var(--border2); }
.badge-purple { background: var(--purple-dim); color: var(--purple); border: 1px solid var(--purple-border); }
.badge-blue   { background: var(--blue-dim);   color: var(--blue);   border: 1px solid var(--blue-border); }
.badge-orange { background: var(--orange-dim); color: var(--orange); border: 1px solid var(--orange-border); }
.badge-elephant-bull { background: var(--green-dim); color: var(--green); border: 1px solid var(--orange-border); }
.badge-elephant-bear { background: var(--red-dim);   color: var(--red);   border: 1px solid var(--orange-border); }

/* ── Score badges ────────────────────────────────────────────────────────────── */
.score-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--mono);
  font-size: 11.5px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: var(--r-sm);
  border: 1px solid transparent;
}
.score-strong { color: var(--green);  background: var(--green-dim);  border-color: var(--green-border); }
.score-watch  { color: var(--yellow); background: var(--yellow-dim); border-color: var(--yellow-border); }
.score-weak   { color: var(--blue);   background: var(--blue-dim);   border-color: var(--blue-border); }
.score-avoid  { color: var(--muted);  background: var(--surface2);   border-color: var(--border2); }
.score-label  { font-weight: 400; font-size: 10px; opacity: 0.8; }

/* ── NY SIGNAL badge ─────────────────────────────────────────────────────────── */
.new-signal-badge {
  display: inline-block;
  font-size: 8.5px;
  font-weight: 900;
  letter-spacing: 0.06em;
  padding: 1px 5px;
  border-radius: 3px;
  background: #ff3d00;
  color: #fff;
  margin-left: 6px;
  vertical-align: middle;
  animation: new-signal-pulse 0.9s ease-in-out infinite;
}
@keyframes new-signal-pulse {
  0%, 100% { opacity: 1;   transform: scale(1); }
  50%       { opacity: 0.6; transform: scale(1.08); }
}

/* ── Dot indicators ──────────────────────────────────────────────────────────── */
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
  background: currentColor;
}
.dot-green  { background: var(--green);  box-shadow: 0 0 6px var(--green); }
.dot-yellow { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }
.dot-red    { background: var(--red); }
.dot-gray   { background: var(--muted); }
.dot-pulse  { animation: dot-pulse 1.2s ease-in-out infinite; }
@keyframes dot-pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── Spinner ─────────────────────────────────────────────────────────────────── */
.spinner {
  display: inline-block;
  width: 14px; height: 14px;
  border: 2px solid var(--border2);
  border-top-color: var(--yellow);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  vertical-align: middle;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Empty state ─────────────────────────────────────────────────────────────── */
.empty { text-align: center; color: var(--muted); padding: 32px; font-size: 13px; }

/* ── Market & info banners ───────────────────────────────────────────────────── */
.market-banner {
  background: var(--yellow-dim);
  border: 1px solid var(--yellow-border);
  color: var(--yellow);
  padding: 8px 14px;
  border-radius: var(--r-sm);
  font-size: 12.5px;
  margin-bottom: 14px;
}
.info-banner {
  background: var(--blue-dim);
  border: 1px solid var(--blue-border);
  color: #7aa8f0;
  padding: 8px 14px;
  border-radius: var(--r-sm);
  font-size: 12.5px;
  margin-bottom: 14px;
}
.info-banner-proxy {
  background: rgba(245,197,24,0.06);
  border-color: var(--yellow-border);
  color: rgba(245,197,24,0.8);
  line-height: 1.55;
}
.info-banner-proxy strong { color: var(--yellow); }
.qqq-proxy-tag {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  padding: 2px 7px; border-radius: 8px;
  background: rgba(245,197,24,0.12);
  color: var(--yellow);
  border: 1px solid var(--yellow-border);
  vertical-align: middle;
  margin-left: 6px;
  letter-spacing: 0.04em;
}

/* ── Confidence bar ──────────────────────────────────────────────────────────── */
.conf-wrap { display: flex; align-items: center; gap: 6px; min-width: 80px; }
.conf-bar-bg { flex: 1; background: var(--border2); border-radius: 2px; height: 5px; }
.conf-bar { height: 5px; border-radius: 2px; transition: width 0.3s; }
.conf-text { font-size: 11px; font-family: var(--mono); color: var(--muted); min-width: 28px; text-align: right; }

/* ── Misc value classes ──────────────────────────────────────────────────────── */
.mono { font-family: var(--mono); }
.sym { font-weight: 700; font-size: 13px; }
.price-cell { font-family: var(--mono); font-weight: 600; }
.val-null { color: var(--muted); }
.val-ok   { color: var(--text); }
.pos { font-family: var(--mono); font-weight: 700; font-size: 13px; }
.pos-long  { color: var(--green); }
.pos-short { color: var(--red); }
.pos-zero  { color: var(--muted); }
.note-cell { color: var(--muted); font-size: 11px; max-width: 160px; overflow: hidden; text-overflow: ellipsis; }
.actions-cell { display: flex; gap: 4px; }

/* ── Table (legacy, kept for old sections) ───────────────────────────────────── */
.table-wrap { overflow-x: auto; border-radius: var(--r); border: 1px solid var(--border); }
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
  min-width: 900px;
}
thead th {
  background: var(--surface2);
  padding: 8px 10px;
  text-align: left;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--muted);
  white-space: nowrap;
  border-bottom: 1px solid var(--border);
}
tbody tr {
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}
tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: var(--surface2); }
tbody td {
  padding: 9px 10px;
  vertical-align: middle;
  white-space: nowrap;
}
.row-elephant-bull { background: rgba(34, 197, 94, 0.04); }
.row-elephant-bear { background: rgba(239, 68, 68, 0.04); }
.row-tfs           { background: rgba(168, 85, 247, 0.05); }

/* ── Best grid container ─────────────────────────────────────────────────────── */
.best-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 12px;
  margin-bottom: 8px;
}

/* ── Legacy best-card (BestCard) still used ─────────────────────────────────── */
.best-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 16px;
  position: relative;
  overflow: hidden;
}
.best-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
}
.best-card.state-HIGH_QUALITY_NARROW::before { background: var(--yellow); }
.best-card.state-MEDIUM_NARROW::before { background: #f59e0b; }
.best-card.state-REGULAR_TREND::before { background: var(--blue); }

.best-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}
.best-symbol { font-size: 1.2rem; font-weight: 800; }
.best-price { font-size: 1.1rem; font-weight: 600; font-family: var(--mono); }
.best-signal-badge { margin-top: 4px; }

.best-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px 12px;
  font-size: 11.5px;
  color: var(--muted);
  margin: 8px 0;
}
.best-stats span { color: var(--text); font-family: var(--mono); }

.best-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }

.best-forklaring {
  font-size: 11.5px;
  color: var(--muted);
  margin-top: 8px;
  line-height: 1.5;
  border-top: 1px solid var(--border);
  padding-top: 8px;
}

.best-v2-scores {
  display: flex;
  gap: 10px;
  margin: 8px 0 4px;
  flex-wrap: wrap;
}
.best-v2-score-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.best-v2-score-label {
  font-size: 9.5px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
}
.best-reasons {
  margin: 6px 0 0;
  padding: 8px 10px 8px 22px;
  background: rgba(255,255,255,0.03);
  border-left: 2px solid var(--border2);
  border-radius: 0 4px 4px 0;
  font-size: 11px;
  color: var(--muted);
  line-height: 1.6;
  list-style: disc;
}
.best-reasons li { margin-bottom: 1px; }

/* ── Legacy guide-box ────────────────────────────────────────────────────────── */
.guide-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  margin-bottom: 16px;
  overflow: hidden;
}
.guide-toggle {
  width: 100%;
  background: none;
  border: none;
  color: var(--text);
  font-size: 13px;
  font-weight: 600;
  padding: 10px 14px;
  text-align: left;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
}
.guide-toggle:hover { background: rgba(255,255,255,0.03); }
.guide-list {
  margin: 0;
  padding: 4px 14px 14px 28px;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.guide-list li {
  font-size: 12.5px;
  color: var(--muted);
  line-height: 1.5;
}
.guide-list li strong { color: var(--text); }

/* ── Legacy QQQ card ─────────────────────────────────────────────────────────── */
.qqq-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}
.qqq-status {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  padding: 12px 18px;
  gap: 0;
}
.qqq-status-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 4px 24px 4px 0;
  margin-right: 24px;
  border-right: 1px solid var(--border);
  min-width: 72px;
}
.qqq-status-item:last-child { border-right: none; margin-right: 0; padding-right: 0; }
.qqq-label {
  font-size: 9.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--muted);
  margin-bottom: 3px;
}
.qqq-val {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--text);
}
.qqq-val.mono { font-family: var(--mono); }
.qqq-val.green { color: var(--green); }
.qqq-val.red { color: var(--red); }

/* ── Legacy status-bar ───────────────────────────────────────────────────────── */
.status-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 12px;
  color: var(--muted);
  flex-wrap: wrap;
}

/* ── Legacy section ──────────────────────────────────────────────────────────── */
.section { margin-bottom: 24px; }
.section-title {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
  padding: 4px 0;
  border-bottom: 1px solid var(--border);
}

/* ── Page hero ───────────────────────────────────────────────────────────────── */
.page-hero { padding: 0 0 20px; margin-bottom: 20px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
.hero-left { display: flex; flex-direction: column; gap: 4px; }
.hero-title { font-size: 1.6rem; font-weight: 900; letter-spacing: -0.03em; line-height: 1; }
.hero-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
.hero-sub strong { color: var(--text); }
.hero-accent-blue   { color: var(--blue); }
.hero-accent-yellow { color: var(--yellow); }
.hero-accent-orange { color: var(--orange); }

/* Legacy page-header, used nowhere now but keep for safety */
.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20px 0 14px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 16px;
  flex-wrap: wrap;
  gap: 10px;
}
.page-title { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 2px; }
.page-subtitle { font-size: 11px; color: var(--muted); letter-spacing: 0.04em; }
.stocks-accent { color: var(--blue); }
.nasdaq-accent { color: var(--yellow); }
.crypto-accent { color: var(--orange); }

/* ── ScoreMeter ──────────────────────────────────────────────────────────────── */
.score-meter { display:flex; align-items:center; gap:8px; }
.score-meter-track { flex:1; height:5px; background:var(--border2); border-radius:3px; overflow:hidden; }
.score-meter-fill { height:100%; border-radius:3px; transition:width 0.4s; }
.score-meter-num { font-family:var(--mono); font-weight:700; font-size:13px; min-width:26px; text-align:right; }
.score-meter-tag { font-size:10px; color:var(--muted); min-width:38px; }

/* ── HealthChips ─────────────────────────────────────────────────────────────── */
.health-chips { display:flex; flex-wrap:wrap; gap:6px; margin:8px 0; }
.health-chip { display:flex; flex-direction:column; align-items:center; gap:1px; padding:4px 8px; border-radius:var(--r-sm); border:1px solid var(--border2); background:var(--surface2); min-width:52px; }
.chip-label { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--muted); }
.chip-value { font-size:11px; font-weight:600; color:var(--text); }
.chip-good { border-color:var(--green-border); background:var(--green-dim); }
.chip-good .chip-value { color:var(--green); }
.chip-bad  { border-color:var(--red-border);    background:var(--red-dim); }
.chip-bad  .chip-value { color:var(--red); }
.chip-warn { border-color:var(--yellow-border);  background:var(--yellow-dim); }
.chip-warn .chip-value { color:var(--yellow); }

/* ── WhyBox ──────────────────────────────────────────────────────────────────── */
.why-box { background:rgba(255,255,255,0.03); border-left:3px solid var(--border2); border-radius:0 var(--r-sm) var(--r-sm) 0; padding:10px 12px; margin-top:10px; }
.why-box-title { font-size:10.5px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px; }
.why-list { list-style:none; display:flex; flex-direction:column; gap:4px; }
.why-list li { font-size:12px; color:var(--muted); line-height:1.5; padding-left:12px; position:relative; }
.why-list li::before { content:'•'; position:absolute; left:2px; color:var(--border2); }

/* ── MarketRegimeBadge ───────────────────────────────────────────────────────── */
.regime-badge { display:inline-flex; align-items:center; gap:5px; padding:3px 9px; border-radius:var(--r-sm); font-size:10.5px; font-weight:700; border:1px solid; }
.regime-BULLISH  { background:var(--green-dim);  color:var(--green);  border-color:var(--green-border); }
.regime-BEARISH  { background:var(--red-dim);    color:var(--red);    border-color:var(--red-border); }
.regime-CHOPPY   { background:var(--yellow-dim); color:var(--yellow); border-color:var(--yellow-border); }
.regime-HIGH_RISK{ background:var(--purple-dim); color:var(--purple); border-color:var(--purple-border); }
.regime-UNKNOWN  { background:var(--surface2);   color:var(--muted);  border-color:var(--border2); }

/* ── SummaryStrip ────────────────────────────────────────────────────────────── */
.summary-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:20px; }
.sum-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r); padding:12px 14px; display:flex; flex-direction:column; gap:2px; }
.sum-card-icon { font-size:16px; margin-bottom:2px; }
.sum-card-count { font-size:1.5rem; font-weight:800; line-height:1; }
.sum-card-label { font-size:10.5px; color:var(--muted); font-weight:600; }
.sum-green .sum-card-count { color:var(--green); }
.sum-yellow .sum-card-count { color:var(--yellow); }
.sum-blue .sum-card-count { color:var(--blue); }
.sum-muted .sum-card-count { color:var(--muted); }

/* ── SymbolCard ──────────────────────────────────────────────────────────────── */
.symbol-cards { display:flex; flex-direction:column; gap:8px; }
.symbol-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r); padding:14px 16px; transition:border-color 0.15s; }
.symbol-card:hover { border-color:var(--border2); }
.symbol-card-top { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:8px; }
.symbol-card-left { display:flex; flex-direction:column; gap:4px; }
.sym-name { font-size:1rem; font-weight:800; letter-spacing:-0.01em; }
.symbol-card-badges { display:flex; gap:6px; flex-wrap:wrap; align-items:center; }
.symbol-card-right { text-align:right; flex-shrink:0; }
.symbol-card-price { font-family:var(--mono); font-weight:700; font-size:1rem; margin-bottom:4px; }
.symbol-card-desc { font-size:12px; color:var(--muted); line-height:1.5; margin:6px 0; border-left:2px solid var(--border2); padding-left:8px; }
.symbol-card-footer { display:flex; align-items:center; justify-content:space-between; gap:8px; margin-top:8px; flex-wrap:wrap; }
.symbol-card-actions { display:flex; gap:6px; flex-shrink:0; }
.symbol-card-detail { border-top:1px solid var(--border); margin-top:10px; padding-top:10px; }
.symbol-card-stats { display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:4px 16px; margin-top:8px; font-size:11.5px; }
.stat-row { display:flex; justify-content:space-between; color:var(--muted); }
.stat-row span { color:var(--text); font-family:var(--mono); }
.stat-row .s-green { color:var(--green); }
.stat-row .s-red { color:var(--red); }

/* ── Section header ──────────────────────────────────────────────────────────── */
.sec { margin-bottom:28px; }
.sec-head { margin-bottom:12px; }
.sec-title { font-size:0.95rem; font-weight:800; letter-spacing:-0.01em; color:var(--text); margin-bottom:3px; display:flex; align-items:center; gap:8px; }
.sec-count { font-size:0.75rem; color:var(--muted); font-weight:600; background:var(--surface2); border:1px solid var(--border); border-radius:12px; padding:1px 8px; }
.sec-desc { font-size:12px; color:var(--muted); line-height:1.5; }

/* ── BestCardV2 ──────────────────────────────────────────────────────────────── */
.best-card-v2 { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:20px; position:relative; overflow:hidden; }
.best-card-v2::before { content:''; position:absolute; top:0;left:0;right:0; height:3px; border-radius:var(--r-lg) var(--r-lg) 0 0; }
.best-card-v2.bc-green::before { background:linear-gradient(90deg,var(--green),rgba(34,197,94,0.3)); box-shadow:0 0 12px rgba(34,197,94,0.3); }
.best-card-v2.bc-yellow::before { background:linear-gradient(90deg,var(--yellow),rgba(245,197,24,0.3)); box-shadow:0 0 12px rgba(245,197,24,0.3); }
.best-card-v2.bc-blue::before { background:linear-gradient(90deg,var(--blue),rgba(59,130,246,0.3)); }
.best-card-v2.bc-orange::before { background:linear-gradient(90deg,var(--orange),rgba(249,115,22,0.3)); }
.bc-rank { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--muted); margin-bottom:6px; }
.bc-head { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px; }
.bc-symbol { font-size:1.4rem; font-weight:900; letter-spacing:-0.02em; margin-bottom:4px; }
.bc-price { font-family:var(--mono); font-size:1.1rem; font-weight:700; }
.bc-action { font-size:12.5px; color:var(--muted); line-height:1.5; margin:10px 0; padding:8px 10px; background:rgba(255,255,255,0.03); border-radius:var(--r-sm); }
.bc-triggers { display:grid; grid-template-columns:1fr 1fr; gap:6px; margin:10px 0; }
.bc-trigger { padding:6px 10px; border-radius:var(--r-sm); font-size:11.5px; font-family:var(--mono); }
.bc-trigger-long  { background:var(--green-dim);  border:1px solid var(--green-border); }
.bc-trigger-short { background:var(--red-dim);    border:1px solid var(--red-border); }
.bc-trigger-label { font-size:9.5px; font-weight:700; text-transform:uppercase; color:var(--muted); display:block; margin-bottom:2px; }
.bc-trigger-long  .bc-trigger-label { color:var(--green); }
.bc-trigger-short .bc-trigger-label { color:var(--red); }
.bc-trigger-val  { font-size:13.5px; font-weight:800; display:block; }
.bc-trigger-hint { font-size:9px; color:var(--muted); display:block; margin-top:2px; font-family:var(--font); }
.bc-actions { display:flex; gap:6px; flex-wrap:wrap; margin-top:14px; }

/* ── QQQ Premium card ────────────────────────────────────────────────────────── */
.qqq-premium { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); padding:20px; position:relative; overflow:hidden; }
.qqq-premium::before { content:''; position:absolute; top:0;left:0;right:0;height:3px; background:linear-gradient(90deg,var(--yellow),rgba(245,197,24,0.2)); }
.qqq-prem-head { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px; }
.qqq-prem-sym { font-size:1.3rem; font-weight:900; margin-bottom:4px; }
.qqq-prem-sub { font-size:11px; color:var(--muted); }
.qqq-prem-price { font-family:var(--mono); font-size:1.4rem; font-weight:800; text-align:right; }
.qqq-prem-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:6px; margin-top:12px; }
.qqq-prem-stat { background:var(--surface2); border:1px solid var(--border); border-radius:var(--r-sm); padding:8px 10px; }
.qqq-prem-stat-label { font-size:9.5px; color:var(--muted); font-weight:700; text-transform:uppercase; margin-bottom:3px; }
.qqq-prem-stat-val { font-size:13px; font-weight:700; font-family:var(--mono); }
.qqq-prem-market { margin-top:12px; padding-top:12px; border-top:1px solid var(--border); }
.qqq-prem-market-title { font-size:10px; font-weight:700; text-transform:uppercase; color:var(--muted); margin-bottom:6px; }
.qqq-prem-market-reasons { list-style:none; display:flex; flex-direction:column; gap:3px; }
.qqq-prem-market-reasons li { font-size:11.5px; color:var(--muted); padding-left:10px; position:relative; }
.qqq-prem-market-reasons li::before { content:'→'; position:absolute; left:0; font-size:9px; }

/* ── Guide v2 ────────────────────────────────────────────────────────────────── */
.guide-v2 { background:var(--surface); border:1px solid var(--border); border-radius:var(--r); margin-bottom:20px; overflow:hidden; }
.guide-v2-toggle { width:100%; background:none; border:none; color:var(--text); font-size:13px; font-weight:600; padding:12px 16px; text-align:left; cursor:pointer; display:flex; align-items:center; justify-content:space-between; gap:8px; font-family:var(--font); }
.guide-v2-toggle:hover { background:rgba(255,255,255,0.02); }
.guide-v2-toggle-left { display:flex; align-items:center; gap:8px; }
.guide-v2-body { padding:0 16px 16px; display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:8px; }
.guide-item { background:var(--surface2); border:1px solid var(--border); border-radius:var(--r-sm); padding:10px 12px; }
.guide-item-icon { font-size:1.2rem; margin-bottom:4px; }
.guide-item-title { font-size:11.5px; font-weight:700; color:var(--text); margin-bottom:3px; }
.guide-item-desc { font-size:11px; color:var(--muted); line-height:1.4; }

/* ── Status bar v2 ───────────────────────────────────────────────────────────── */
.status-bar-v2 { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.status-pill { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:20px; border:1px solid var(--border2); background:var(--surface2); font-size:11px; color:var(--muted); white-space:nowrap; }
.status-pill.s-ok { border-color:var(--green-border); color:var(--green); background:var(--green-dim); }
.status-pill.s-scan { border-color:var(--yellow-border); color:var(--yellow); background:var(--yellow-dim); }

/* ── Live command center ───────────────────────────────────────────────────── */
.live-command-center {
  display: flex;
  flex-direction: column;
  gap: 18px;
}
.live-hero {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(59,130,246,.24);
  border-radius: 14px;
  background:
    radial-gradient(circle at 18% 0%, rgba(34,197,94,.18), transparent 36%),
    radial-gradient(circle at 82% 10%, rgba(59,130,246,.18), transparent 34%),
    linear-gradient(135deg, #090d16 0%, #101827 60%, #0b1019 100%);
  padding: 24px;
  box-shadow: 0 18px 70px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.06);
}
.live-hero-bg {
  position: absolute;
  inset: 0;
  opacity: .22;
  background-image:
    linear-gradient(90deg, transparent 0 18px, rgba(59,130,246,.28) 19px, transparent 20px),
    linear-gradient(180deg, transparent 0 18px, rgba(34,197,94,.2) 19px, transparent 20px);
  background-size: 42px 42px;
  mask-image: radial-gradient(circle at 50% 10%, black, transparent 72%);
  pointer-events: none;
}
.live-hero-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
}
.live-kicker {
  color: #67e8f9;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .12em;
  margin-bottom: 6px;
}
.live-hero h1 {
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: .95;
  letter-spacing: -0.04em;
  margin: 0 0 10px;
}
.live-hero p {
  max-width: 680px;
  color: rgba(221,227,242,.72);
  font-size: 14px;
}
.live-refresh-btn {
  border: 1px solid rgba(34,197,94,.35);
  background: rgba(34,197,94,.1);
  color: var(--green);
  border-radius: 999px;
  padding: 9px 14px;
  font-weight: 800;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 7px;
}
.live-hero-stats {
  position: relative;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10px;
  margin-top: 24px;
}
.live-stat {
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(7,11,20,.72);
  border-radius: 10px;
  padding: 11px 12px;
}
.live-stat span {
  display: block;
  color: var(--muted);
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .07em;
  margin-bottom: 4px;
}
.live-stat strong {
  color: var(--text);
  font-size: 15px;
}
.live-stat strong.strong { color: var(--green); }
.live-stat strong.watch { color: var(--yellow); }
.live-stat strong.risk { color: var(--red); }
.live-command-section {
  border: 1px solid var(--border);
  background: linear-gradient(180deg, rgba(17,21,32,.96), rgba(12,16,25,.96));
  border-radius: 12px;
  padding: 16px;
}
.live-section-head {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}
.live-section-title {
  font-size: 15px;
  font-weight: 900;
  letter-spacing: -0.01em;
}
.live-section-sub {
  color: var(--muted);
  font-size: 12px;
  margin-top: 2px;
}
.live-calm-state {
  border: 1px dashed rgba(148,163,184,.22);
  border-radius: 10px;
  padding: 24px;
  text-align: center;
  color: var(--muted);
  background: rgba(255,255,255,.025);
}
.pulse-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 10px;
}
.pulse-card {
  text-align: left;
  border: 1px solid rgba(255,255,255,.09);
  background: #0b1220;
  color: var(--text);
  border-radius: 10px;
  padding: 13px;
  cursor: pointer;
  min-height: 150px;
  overflow: hidden;
  position: relative;
}
.pulse-card::before {
  content: '';
  position: absolute;
  inset: -40% -20% auto;
  height: 95px;
  opacity: .28;
  filter: blur(28px);
}
.pulse-strong::before { background: var(--green); }
.pulse-risk::before { background: var(--red); }
.pulse-watch::before { background: var(--yellow); }
.pulse-wait::before { background: var(--blue); }
.pulse-card-top, .pulse-card-bottom {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}
.pulse-symbol {
  font-size: 24px;
  font-weight: 950;
  letter-spacing: -0.04em;
}
.pulse-status {
  font-size: 10px;
  font-weight: 900;
  letter-spacing: .08em;
  color: var(--muted);
}
.pulse-line {
  position: relative;
  width: 100%;
  height: 48px;
  margin: 9px 0;
}
.pulse-line polyline {
  fill: none;
  stroke: currentColor;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
  stroke-dasharray: 260;
  stroke-dashoffset: 260;
  animation: pulse-draw 2.3s ease-in-out infinite;
}
.pulse-strong { color: var(--green); box-shadow: 0 0 28px rgba(34,197,94,.08); }
.pulse-risk { color: var(--red); box-shadow: 0 0 28px rgba(239,68,68,.08); }
.pulse-watch { color: var(--yellow); }
.pulse-wait { color: var(--blue); }
.pulse-card-bottom {
  color: rgba(221,227,242,.78);
  font-size: 12px;
  font-weight: 800;
}
.pulse-why {
  position: relative;
  color: var(--muted);
  font-size: 11.5px;
  line-height: 1.4;
  margin-top: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
@keyframes pulse-draw {
  0% { stroke-dashoffset: 260; opacity: .35; }
  45%, 65% { stroke-dashoffset: 0; opacity: 1; }
  100% { stroke-dashoffset: -260; opacity: .35; }
}
.live-best-card {
  border-radius: 12px;
  padding: 18px;
  border: 1px solid rgba(255,255,255,.09);
  background: linear-gradient(135deg, rgba(15,23,42,.98), rgba(10,15,24,.98));
}
.live-best-strong { border-color: rgba(34,197,94,.34); box-shadow: inset 0 1px 0 rgba(34,197,94,.12); }
.live-best-risk { border-color: rgba(239,68,68,.34); }
.live-best-watch { border-color: rgba(245,197,24,.3); }
.live-best-main {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 14px;
}
.live-best-symbol {
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 950;
  line-height: .92;
  letter-spacing: -0.06em;
}
.live-best-dir {
  color: var(--muted);
  font-weight: 800;
  margin-top: 8px;
}
.live-best-action {
  border: 1px solid var(--green-border);
  background: var(--green-dim);
  color: var(--green);
  border-radius: 999px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
}
.live-best-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
}
.live-best-grid div {
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.035);
  border-radius: 8px;
  padding: 10px;
}
.live-best-grid span {
  display: block;
  color: var(--muted);
  font-size: 10px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: 5px;
}
.live-best-grid strong {
  display: block;
  font-size: 12px;
  line-height: 1.45;
  color: rgba(221,227,242,.9);
}
.live-best-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--border);
}
.live-best-empty {
  display: flex;
  flex-direction: column;
  gap: 4px;
  color: var(--muted);
}
.live-best-empty strong { color: var(--text); }
.live-simple-list {
  display: flex;
  flex-direction: column;
}
.live-simple-row {
  display: grid;
  grid-template-columns: 38px 90px 86px 86px 1fr;
  align-items: center;
  gap: 8px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.live-simple-row:last-child { border-bottom: 0; }
.live-simple-rank, .live-simple-score, .live-simple-reason { color: var(--muted); font-size: 12px; }
.live-simple-symbol { font-weight: 900; font-size: 16px; }
.live-simple-status {
  font-size: 10px;
  font-weight: 900;
  letter-spacing: .06em;
}
.live-simple-status.strong { color: var(--green); }
.live-simple-status.watch { color: var(--yellow); }
.live-simple-status.risk { color: var(--red); }
.live-simple-status.wait { color: var(--blue); }
.live-simple-reason {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.live-advanced-wrap {
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(255,255,255,.02);
  padding: 12px;
}
.live-advanced-toggle {
  width: 100%;
  border: 0;
  background: transparent;
  color: var(--muted);
  cursor: pointer;
  font-weight: 800;
  text-align: left;
  padding: 4px;
}
.live-advanced-toggle:hover { color: var(--text); }
.live-advanced-body { margin-top: 12px; }
@media (max-width: 760px) {
  .live-hero { padding: 18px; }
  .live-hero-content, .live-best-main { flex-direction: column; }
  .live-hero-stats, .live-best-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .live-simple-row { grid-template-columns: 30px 1fr auto; }
  .live-simple-score, .live-simple-reason { grid-column: 2 / -1; }
}
@media (max-width: 480px) {
  .live-hero-stats, .live-best-grid { grid-template-columns: 1fr; }
}

/* ── No-data banner ──────────────────────────────────────────────────────────── */
.no-data-banner { background:rgba(255,255,255,0.04); border:1px solid var(--border2); border-radius:var(--r); padding:20px; text-align:center; color:var(--muted); font-size:13px; }
.no-data-banner strong { color:var(--text); display:block; margin-bottom:6px; font-size:14px; }

/* ── Responsive ──────────────────────────────────────────────────────────────── */
@media (max-width: 700px) {
  .nav { padding: 0 12px; height: 48px; }
  .nav-link { padding: 0 10px; font-size: 12px; }
  .nav-brand { font-size: 0.85rem; }
  .btn-alert { font-size: 10px; padding: 4px 8px; }
}
@media (max-width: 600px) {
  .summary-strip { grid-template-columns: repeat(2,1fr); }
  .hero-title { font-size: 1.3rem; }
  .bc-triggers { grid-template-columns: 1fr; }
  .qqq-prem-grid { grid-template-columns: repeat(2,1fr); }
  .best-grid { grid-template-columns: 1fr; }
}

/* ── Hero accent purple ──────────────────────────────────────────────────────── */
.hero-accent-purple { color: var(--purple); }

/* ── Historik — disclaimer ───────────────────────────────────────────────────── */
.hist-disclaimer {
  background: var(--purple-dim);
  border: 1px solid var(--purple-border);
  color: var(--purple);
  padding: 8px 14px;
  border-radius: var(--r-sm);
  font-size: 12px;
  margin-bottom: 16px;
}

/* ── Stats strip ─────────────────────────────────────────────────────────────── */
.hist-stats-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 10px;
  margin-bottom: 16px;
}
.hist-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 12px 16px;
  text-align: center;
}
.hist-stat-val {
  font-size: 1.4rem;
  font-weight: 800;
  font-family: var(--mono);
  color: var(--text);
  line-height: 1.1;
}
.hist-stat-label {
  font-size: 10.5px;
  color: var(--muted);
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* ── Filters ─────────────────────────────────────────────────────────────────── */
.hist-filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 20px;
  padding: 12px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
}
.hist-filter-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 130px;
}
.hist-filter-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}
.hist-select {
  background: var(--surface2);
  border: 1px solid var(--border2);
  color: var(--text);
  border-radius: var(--r-sm);
  padding: 5px 8px;
  font-size: 12.5px;
  font-family: var(--font);
  cursor: pointer;
  outline: none;
}
.hist-select:focus { border-color: var(--purple); }

/* ── Signal grid ─────────────────────────────────────────────────────────────── */
.hist-signal-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 12px;
}

/* ── Signal card ─────────────────────────────────────────────────────────────── */
.hist-signal-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 16px;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.hist-card-accent {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  opacity: 0.8;
}
.hist-card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-top: 4px;
}
.hist-card-sym {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.01em;
}
.hist-card-time {
  font-size: 11px;
  color: var(--muted);
  font-family: var(--mono);
}
.hist-card-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.hist-card-scores {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  font-size: 12px;
  padding: 8px 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.hist-score-item { display: flex; flex-direction: column; gap: 2px; }
.hist-score-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.hist-card-forklaring {
  font-size: 12px;
  color: var(--muted);
  font-style: italic;
  line-height: 1.5;
}

/* ── Signal time block ────────────────────────────────────────────────────────── */
.hist-signal-time-block {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  background: var(--surface2);
  border-radius: var(--r-sm);
  padding: 6px 10px;
}
.hist-signal-time-label {
  color: var(--muted);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  flex-shrink: 0;
}
.hist-signal-time-val {
  font-family: var(--mono);
  font-weight: 700;
  color: var(--text);
}
.hist-signal-time-swe {
  font-family: var(--mono);
  color: var(--muted);
  font-size: 11px;
}
.hist-signal-time-tf {
  font-size: 10px;
  color: var(--blue);
  background: color-mix(in srgb, var(--blue) 15%, transparent);
  border-radius: 3px;
  padding: 1px 6px;
  font-weight: 600;
  margin-left: auto;
}

/* ── Card action buttons ─────────────────────────────────────────────────────── */
.hist-card-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.hist-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 600;
  padding: 5px 10px;
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
  font-family: inherit;
}
.hist-tv-btn {
  background: color-mix(in srgb, #2962FF 12%, transparent);
  color: #5c8fff;
  border-color: color-mix(in srgb, #2962FF 30%, transparent);
}
.hist-tv-btn:hover {
  background: color-mix(in srgb, #2962FF 22%, transparent);
  border-color: #2962FF;
}
.hist-copy-btn {
  background: var(--surface2);
  color: var(--muted);
  border-color: var(--border);
}
.hist-copy-btn:hover {
  background: var(--border2);
  color: var(--text);
}
.hist-tv-goto {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  font-size: 12px;
  margin-bottom: 8px;
  padding: 6px 10px;
  background: color-mix(in srgb, #2962FF 8%, transparent);
  border: 1px solid color-mix(in srgb, #2962FF 20%, transparent);
  border-radius: var(--r-sm);
}
.hist-tv-goto-label {
  color: var(--muted);
  font-size: 11px;
}
.hist-tv-goto-date {
  color: var(--text);
  font-family: var(--mono);
  font-size: 13px;
}
.hist-tv-goto-sep {
  color: var(--muted);
  font-size: 11px;
}
.hist-tv-goto-time {
  color: #5c8fff;
  font-family: var(--mono);
  font-size: 15px;
  letter-spacing: 0.04em;
}
.hist-tv-help {
  font-size: 11px;
  color: var(--muted);
  margin-top: 6px;
  line-height: 1.4;
}

/* ── TradingView hint banner ─────────────────────────────────────────────────── */
.hist-tv-hint {
  font-size: 12px;
  color: var(--muted);
  background: color-mix(in srgb, #2962FF 8%, transparent);
  border: 1px solid color-mix(in srgb, #2962FF 20%, transparent);
  border-radius: var(--r-sm);
  padding: 8px 12px;
  margin-bottom: 12px;
  line-height: 1.5;
}

/* ── Outcomes ────────────────────────────────────────────────────────────────── */
.hist-outcomes {
  background: var(--surface2);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  font-size: 12px;
}
.hist-outcome-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  margin-bottom: 4px;
}
.hist-outcome-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.hist-outcome-label { color: var(--muted); min-width: 160px; }
.hist-outcome-sub { font-size: 11px; color: var(--muted); margin-left: auto; }
.hist-failure-reason { font-size: 11px; color: var(--muted); margin-top: 4px; }

/* ── Learning summary ────────────────────────────────────────────────────────── */
.hist-learning {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.hist-learning-bullets { display: flex; flex-direction: column; gap: 8px; }
.hist-bullet { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; line-height: 1.5; }
.hist-bullet-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }
.hist-winrate-bar {
  background: var(--surface2);
  border-radius: var(--r-sm);
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.hist-winrate-label { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.hist-sub-title { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.hist-score-ranges { display: flex; flex-direction: column; gap: 8px; }
.hist-score-range-row { display: flex; align-items: center; gap: 10px; }
.hist-range-label { font-family: var(--mono); font-size: 11px; color: var(--muted); min-width: 50px; }
.hist-symbol-ranking { display: flex; flex-direction: column; gap: 8px; }
.hist-sym-rank-row { display: flex; align-items: center; gap: 10px; }
.hist-sym-rank-pos { font-family: var(--mono); font-size: 11px; min-width: 24px; }
.hist-sym-rank-name { font-weight: 700; font-size: 12px; min-width: 80px; }

/* ── Empty state ─────────────────────────────────────────────────────────────── */
.hist-empty {
  text-align: center;
  padding: 48px 24px;
  color: var(--muted);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.hist-empty-icon { font-size: 3rem; }
.hist-empty-title { font-size: 1.1rem; font-weight: 700; color: var(--text); }
.hist-empty-desc { font-size: 13px; max-width: 480px; line-height: 1.6; }
.hist-dev-box {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r-sm);
  padding: 12px 16px;
  font-size: 12px;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 6px;
  max-width: 400px;
  width: 100%;
  margin-top: 8px;
}
.hist-dev-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 4px; }
.hist-dev-box code { font-family: var(--mono); color: var(--green); background: var(--surface); padding: 3px 8px; border-radius: var(--r-sm); font-size: 11.5px; }
.hist-empty-filter { color: var(--muted); padding: 24px; text-align: center; font-size: 13px; }

/* ── Responsive historik ─────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .hist-stats-strip { grid-template-columns: repeat(2, 1fr); }
  .hist-signal-grid { grid-template-columns: 1fr; }
  .hist-filters { flex-direction: column; }
  .hist-filter-group { min-width: 100%; }
}

/* ══════════════════════════════════════════════════════════════════════════════ */
/* REPLAY PAGE                                                                   */
/* ══════════════════════════════════════════════════════════════════════════════ */

/* ── Hero accent green ───────────────────────────────────────────────────────── */
.hero-accent-green { color: var(--green); }

/* ── Run selector grid ───────────────────────────────────────────────────────── */
.rpl-runs-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 10px;
}
.rpl-run-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 16px;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  display: flex;
  flex-direction: column;
  gap: 5px;
  outline: none;
}
.rpl-run-card:hover     { border-color: var(--green-border); background: rgba(34,197,94,0.05); }
.rpl-run-card:focus     { border-color: var(--green); }
.rpl-run-card-active    { border-color: var(--green) !important; background: rgba(34,197,94,0.08) !important; }
.rpl-run-id             { font-size: 10.5px; font-family: var(--mono); font-weight: 700; color: var(--green); letter-spacing: 0.06em; }
.rpl-run-date           { font-size: 12.5px; color: var(--text); font-weight: 600; }
.rpl-run-syms           { font-size: 11px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rpl-run-stats          { display: flex; gap: 18px; margin-top: 4px; }
.rpl-run-stat           { display: flex; flex-direction: column; gap: 1px; }
.rpl-run-stat-val       { font-family: var(--mono); font-weight: 700; font-size: 14px; color: var(--text); }
.rpl-run-stat-label     { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.rpl-run-created        { font-size: 10px; color: var(--muted); margin-top: 2px; }

/* ── Summary strip ───────────────────────────────────────────────────────────── */
.rpl-summary-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 10px;
  margin-bottom: 14px;
}
.rpl-sum-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 12px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.rpl-sum-icon  { font-size: 18px; }
.rpl-sum-val   { font-size: 1.3rem; font-weight: 800; font-family: var(--mono); color: var(--text); line-height: 1.1; }
.rpl-sum-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }

/* ── Symbol ranking ──────────────────────────────────────────────────────────── */
.rpl-sym-ranking {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
  margin-bottom: 14px;
}
.rpl-sym-group       { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--r); padding: 12px 14px; display: flex; flex-direction: column; gap: 8px; }
.rpl-sym-group-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px; }
.rpl-sym-row         { display: flex; align-items: center; gap: 10px; font-size: 12.5px; }
.rpl-sym-pos         { font-family: var(--mono); font-size: 11px; min-width: 20px; }
.rpl-sym-name        { font-weight: 700; min-width: 64px; }
.rpl-sym-events      { font-size: 10.5px; color: var(--muted); margin-left: auto; }

/* ── Insights box ────────────────────────────────────────────────────────────── */
.rpl-insights {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 18px;
  margin-top: 4px;
}
.rpl-insights-title {
  font-size: 10.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  margin-bottom: 10px;
}
.rpl-insights-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
.rpl-insights-list li {
  font-size: 13px;
  color: var(--text);
  padding-left: 16px;
  position: relative;
  line-height: 1.5;
}
.rpl-insights-list li::before { content: '→'; position: absolute; left: 0; color: var(--green); font-size: 11px; top: 2px; }

/* ── Event timeline ──────────────────────────────────────────────────────────── */
.rpl-timeline { display: flex; flex-direction: column; gap: 10px; }

.rpl-event-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 16px;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: border-color 0.1s;
}
.rpl-event-card:hover { border-color: var(--border2); }
.rpl-event-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; opacity: 0.9; }
.rpl-event-top    { display: flex; justify-content: space-between; align-items: flex-start; margin-top: 4px; }
.rpl-event-left   { display: flex; flex-direction: column; gap: 2px; }
.rpl-event-sym    { font-size: 1rem; font-weight: 800; color: var(--text); }
.rpl-event-time   { font-size: 11px; color: var(--muted); font-family: var(--mono); }
.rpl-event-right  { text-align: right; flex-shrink: 0; }
.rpl-event-badges { display: flex; gap: 6px; flex-wrap: wrap; }

.rpl-event-scores {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  padding: 8px 0;
  border-top: 1px solid var(--border);
}
.rpl-score-item  { display: flex; flex-direction: column; gap: 2px; }
.rpl-score-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }

.rpl-event-action {
  font-size: 12px;
  color: var(--muted);
  font-style: italic;
  line-height: 1.5;
  border-left: 2px solid var(--border2);
  padding-left: 8px;
}

/* ── Flag chips ──────────────────────────────────────────────────────────────── */
.rpl-flags { display: flex; gap: 6px; flex-wrap: wrap; }
.rpl-flag-chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--r-sm);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.04em;
  border: 1px solid;
  background: rgba(255,255,255,0.04);
}

/* ── Detail section ──────────────────────────────────────────────────────────── */
.rpl-detail-toggle {
  background: none;
  border: none;
  color: var(--muted);
  font-size: 11px;
  cursor: pointer;
  padding: 0;
  font-family: var(--font);
  text-align: left;
  transition: color 0.1s;
}
.rpl-detail-toggle:hover { color: var(--text); }
.rpl-detail {
  background: rgba(255,255,255,0.03);
  border-left: 3px solid var(--border2);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
  padding: 10px 12px;
}
.rpl-detail-title {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 6px;
}
.rpl-detail-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.rpl-detail-list li {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.5;
  padding-left: 12px;
  position: relative;
}
.rpl-detail-list li::before { content: '•'; position: absolute; left: 2px; color: var(--border2); }

/* ── Backfill panel ──────────────────────────────────────────────────────────── */
.bfp-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  margin-bottom: 16px;
}
.bfp-toggle {
  width: 100%;
  background: none;
  border: none;
  color: var(--text);
  font-family: var(--font);
  font-size: 13.5px;
  font-weight: 700;
  padding: 14px 20px;
  text-align: left;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  transition: background 0.1s;
}
.bfp-toggle:hover { background: rgba(255,255,255,0.025); }
.bfp-toggle-left { display: flex; align-items: center; gap: 10px; }
.bfp-toggle-pill {
  font-size: 10.5px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  border: 1px solid var(--blue-border);
  background: var(--blue-dim);
  color: var(--blue);
}
.bfp-toggle-arrow { font-size: 11px; color: var(--muted); white-space: nowrap; }
.bfp-body {
  border-top: 1px solid var(--border);
  padding: 16px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.bfp-desc { font-size: 12.5px; color: var(--muted); line-height: 1.55; }
.bfp-desc strong { color: var(--text); }
.bfp-crypto-warn {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: var(--yellow-dim);
  border: 1px solid var(--yellow-border);
  border-radius: var(--r-sm);
  padding: 10px 14px;
  font-size: 12.5px;
  color: var(--yellow);
  line-height: 1.5;
}
.bfp-crypto-warn strong { color: var(--text); }
.bfp-form { display: flex; flex-direction: column; gap: 12px; }
.bfp-form-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr auto;
  gap: 12px;
  align-items: end;
}
.bfp-field { display: flex; flex-direction: column; gap: 5px; }
.bfp-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}
.bfp-hint { font-weight: 400; letter-spacing: 0; color: var(--muted2); }
.bfp-source-badge {
  display: inline-flex;
  align-items: center;
  padding: 7px 14px;
  border: 1px solid var(--blue-border);
  border-radius: var(--r-sm);
  background: var(--blue-dim);
  color: var(--blue);
  font-size: 13px;
  font-weight: 700;
  white-space: nowrap;
  height: 36px;
}
.bfp-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.bfp-meta { font-size: 11.5px; color: var(--muted); }

/* Backfill result */
.bfp-result {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 12px 16px;
}
.bfp-result-title {
  font-size: 10.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  margin-bottom: 8px;
}
.bfp-result-rows { display: flex; flex-direction: column; gap: 0; }
.bfp-result-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12.5px;
  padding: 6px 0;
  border-bottom: 1px solid var(--border);
  line-height: 1.4;
}
.bfp-result-row:last-child { border-bottom: none; padding-bottom: 0; }
.bfp-row-sym  { font-weight: 700; min-width: 80px; font-family: var(--mono); color: var(--text); }
.bfp-row-icon { min-width: 16px; text-align: center; flex-shrink: 0; }
.bfp-row-ok   .bfp-row-icon { color: var(--green);  font-weight: 700; }
.bfp-row-warn .bfp-row-icon { color: var(--yellow); font-weight: 700; }
.bfp-row-fail .bfp-row-icon { color: var(--red);    font-weight: 700; }
.bfp-row-skip .bfp-row-icon { color: var(--muted); }
.bfp-row-ok   > span:last-child { color: var(--text); }
.bfp-row-warn > span:last-child { color: var(--yellow); }
.bfp-row-fail > span:last-child { color: var(--red); }
.bfp-row-skip > span:last-child { color: var(--muted); }

/* Data status table */
.bfp-status-section { display: flex; flex-direction: column; gap: 8px; }
.bfp-status-title {
  font-size: 10.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 8px;
}
.bfp-refresh-btn {
  background: none;
  border: none;
  color: var(--muted);
  font-size: 13px;
  cursor: pointer;
  padding: 0 4px;
  line-height: 1;
  transition: color 0.1s;
}
.bfp-refresh-btn:hover:not(:disabled) { color: var(--text); }
.bfp-no-data { font-size: 12px; color: var(--muted); }
.bfp-status-table {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}
.bfp-status-header,
.bfp-status-row {
  display: grid;
  grid-template-columns: 90px 1fr 100px 70px;
  gap: 12px;
  padding: 8px 14px;
  font-size: 12px;
}
.bfp-status-header {
  background: var(--surface3);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}
.bfp-status-row { border-top: 1px solid var(--border); color: var(--text); }
.bfp-status-sym    { font-weight: 700; font-family: var(--mono); }
.bfp-status-range  { font-family: var(--mono); font-size: 11.5px; color: var(--muted); }
.bfp-status-candles{ font-family: var(--mono); font-weight: 700; }
.bfp-status-raw    { font-family: var(--mono); color: var(--muted); }

/* Responsive backfill */
@media (max-width: 760px) {
  .bfp-form-grid { grid-template-columns: 1fr 1fr; }
  .bfp-field-wide { grid-column: span 2; }
  .bfp-status-header,
  .bfp-status-row { grid-template-columns: 70px 1fr 80px; }
  .bfp-status-raw { display: none; }
}
@media (max-width: 500px) {
  .bfp-form-grid { grid-template-columns: 1fr; }
  .bfp-field-wide { grid-column: span 1; }
}

/* ── Run form ────────────────────────────────────────────────────────────────── */
.rpl-form {
  background: var(--surface);
  border: 1px solid var(--green-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  margin-bottom: 24px;
  position: relative;
}
.rpl-form::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--green), rgba(34,197,94,0.3));
}
.rpl-form-header {
  padding: 18px 20px 14px;
  border-bottom: 1px solid var(--border);
}
.rpl-form-title {
  font-size: 0.95rem;
  font-weight: 800;
  color: var(--green);
  letter-spacing: -0.01em;
  margin-bottom: 6px;
}
.rpl-form-desc {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.55;
  max-width: 680px;
}
.rpl-form-desc strong { color: var(--text); }
.rpl-form-body { padding: 16px 20px 18px; }
.rpl-form-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 12px;
  margin-bottom: 14px;
}
.rpl-form-group { display: flex; flex-direction: column; gap: 5px; }
.rpl-form-group-wide { }
.rpl-form-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}
.rpl-form-hint { font-weight: 400; letter-spacing: 0; color: var(--muted2); }
.rpl-form-input {
  background: var(--surface2);
  border: 1px solid var(--border2);
  color: var(--text);
  border-radius: var(--r-sm);
  padding: 7px 10px;
  font-size: 13px;
  font-family: var(--font);
  outline: none;
  transition: border-color 0.15s;
  width: 100%;
}
.rpl-form-input:focus  { border-color: var(--green); }
.rpl-form-input:disabled { opacity: 0.5; cursor: not-allowed; }
.rpl-form-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.rpl-btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 20px;
  background: var(--green);
  color: #000;
  border: none;
  border-radius: var(--r-sm);
  font-size: 13px;
  font-weight: 700;
  font-family: var(--font);
  cursor: pointer;
  transition: opacity 0.15s, background 0.15s;
  white-space: nowrap;
}
.rpl-btn-submit:hover:not(:disabled) { opacity: 0.88; }
.rpl-btn-submit:disabled { opacity: 0.55; cursor: not-allowed; }
.rpl-btn-submitting { background: var(--green); opacity: 0.7; }
.rpl-form-success {
  font-size: 12.5px;
  color: var(--green);
  font-weight: 600;
}
.rpl-form-error {
  margin-top: 10px;
  background: var(--red-dim);
  border: 1px solid var(--red-border);
  color: var(--red);
  border-radius: var(--r-sm);
  padding: 8px 12px;
  font-size: 12.5px;
  line-height: 1.5;
}

/* ── No-candles warning ──────────────────────────────────────────────────────── */
.rpl-no-candles {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: var(--yellow-dim);
  border: 1px solid var(--yellow-border);
  border-radius: var(--r);
  padding: 14px 16px;
  margin-bottom: 16px;
}
.rpl-no-candles-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }
.rpl-no-candles-body { font-size: 13px; color: var(--yellow); line-height: 1.55; }
.rpl-no-candles-body strong { color: var(--text); }

/* ── Confidence Label Badge ──────────────────────────────────────────────────── */
.conf-label { display:inline-flex; align-items:center; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:700; letter-spacing:0.05em; text-transform:uppercase; }
.clf-best    { background:rgba(34,197,94,0.18);   color:var(--green);  border:1px solid var(--green-border); }
.clf-strong  { background:rgba(34,197,94,0.09);   color:#6ee7a0;       border:1px solid rgba(34,197,94,0.25); }
.clf-watch   { background:rgba(245,197,24,0.14);  color:var(--yellow); border:1px solid var(--yellow-border); }
.clf-weak    { background:rgba(87,99,126,0.14);   color:var(--muted);  border:1px solid var(--border2); }
.clf-blocked { background:rgba(239,68,68,0.13);   color:var(--red);    border:1px solid var(--red-border); }

/* ── AutoFilter Banner ───────────────────────────────────────────────────────── */
.af-banner { display:flex; align-items:flex-start; gap:10px; background:rgba(239,68,68,0.06); border:1px solid rgba(239,68,68,0.18); border-radius:var(--r-sm); padding:10px 12px; margin-bottom:10px; }
.af-banner-icon { font-size:13px; flex-shrink:0; margin-top:2px; }
.af-banner-title { font-size:12px; font-weight:700; color:var(--red); margin-bottom:3px; }
.af-banner-reason { font-size:11px; color:rgba(239,68,68,0.75); line-height:1.55; }
.symbol-card-blocked { border-color:rgba(239,68,68,0.2) !important; }

/* ── Confidence Panel (expanded detail) ──────────────────────────────────────── */
.conf-panel { background:rgba(255,255,255,0.02); border:1px solid var(--border); border-radius:var(--r-sm); padding:10px 12px; margin-top:8px; }
.conf-panel-score { font-size:11.5px; color:var(--muted); margin-bottom:8px; }
.conf-panel-score strong { color:var(--text); }
.conf-adj { font-size:10.5px; font-weight:700; margin-left:6px; padding:1px 6px; border-radius:10px; font-family:var(--mono); }
.conf-adj-pos { background:rgba(34,197,94,0.15);  color:var(--green); }
.conf-adj-neg { background:rgba(239,68,68,0.15);   color:var(--red); }
.conf-rows { display:flex; flex-direction:column; gap:4px; margin-top:6px; }
.conf-row { display:flex; align-items:flex-start; gap:8px; font-size:11px; line-height:1.45; }
.conf-row-dot { flex-shrink:0; font-family:var(--mono); font-weight:700; min-width:40px; }
.conf-row-boost .conf-row-dot { color:var(--green); }
.conf-row-block .conf-row-dot { color:var(--red); }
.conf-row-boost { color:rgba(221,227,242,0.65); }
.conf-row-block { color:rgba(239,68,68,0.8); }

/* ── Score delta line (card-level) ───────────────────────────────────────────── */
.conf-score-delta { font-size:11px; color:var(--muted); margin:4px 0 2px; }
.conf-score-delta strong { color:var(--text); }

/* ── Adaptive Edge Panel ─────────────────────────────────────────────────────── */
.ae-panel {
  background: rgba(139,92,246,0.04);
  border: 1px solid rgba(139,92,246,0.18);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-top: 8px;
}
.ae-panel-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}
.ae-panel-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--purple);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  flex-shrink: 0;
}
.ae-panel-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.ae-conf-badge {
  display: inline-flex;
  align-items: center;
  padding: 1px 7px;
  border-radius: 10px;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.04em;
  border: 1px solid;
}
.ae-conf-high   { background: rgba(34,197,94,0.12);   color: var(--green);  border-color: var(--green-border); }
.ae-conf-medium { background: rgba(245,197,24,0.12);  color: var(--yellow); border-color: var(--yellow-border); }
.ae-conf-low    { background: rgba(87,99,126,0.14);   color: var(--muted);  border-color: var(--border2); }
.ae-edge-score {
  font-size: 10px;
  font-family: var(--mono);
  font-weight: 600;
  color: var(--muted);
  padding: 1px 6px;
  border-radius: 8px;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border2);
}
.ae-samples {
  font-size: 10px;
  color: var(--muted2);
}

.ae-adjustment {
  font-size: 11.5px;
  font-weight: 600;
  margin-bottom: 8px;
  padding: 5px 8px;
  border-radius: var(--r-sm);
}
.ae-adj-pos     { background: rgba(34,197,94,0.08);  color: var(--green);  border: 1px solid rgba(34,197,94,0.2); }
.ae-adj-neg     { background: rgba(239,68,68,0.08);  color: var(--red);    border: 1px solid rgba(239,68,68,0.2); }
.ae-adj-neutral { background: rgba(87,99,126,0.08);  color: var(--muted);  border: 1px solid var(--border); }

.ae-factors-wrap { display: flex; flex-direction: column; gap: 8px; margin-bottom: 8px; }
.ae-factor-group {}
.ae-factor-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 5px;
}
.ae-factor-title-pos { color: rgba(34,197,94,0.7); }
.ae-factor-title-neg { color: rgba(249,115,22,0.7); }

.ae-chips { display: flex; flex-wrap: wrap; gap: 5px; }
.ae-chip {
  display: inline-flex;
  align-items: center;
  padding: 3px 9px;
  border-radius: 20px;
  font-size: 10.5px;
  font-weight: 600;
  cursor: default;
  transition: opacity 0.15s;
}
.ae-chip:hover { opacity: 0.85; }
.ae-chip-pos {
  background: rgba(34,197,94,0.1);
  color: var(--green);
  border: 1px solid rgba(34,197,94,0.22);
}
.ae-chip-neg {
  background: rgba(249,115,22,0.1);
  color: var(--orange);
  border: 1px solid rgba(249,115,22,0.22);
}

.ae-summary {
  font-size: 11px;
  color: rgba(221,227,242,0.6);
  font-style: italic;
  border-top: 1px solid rgba(139,92,246,0.1);
  padding-top: 7px;
  margin-top: 2px;
  line-height: 1.5;
}

@media (max-width: 600px) {
  .ae-panel { padding: 8px 10px; }
  .ae-chip  { font-size: 10px; padding: 2px 7px; }
}

/* ── Setup DNA Panel ─────────────────────────────────────────────────────────── */
.dna-panel {
  background: rgba(6,182,212,0.04);
  border: 1px solid rgba(6,182,212,0.18);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-top: 8px;
}
.dna-panel-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 9px;
}
.dna-panel-title {
  font-size: 11px;
  font-weight: 700;
  color: #06b6d4;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  flex-shrink: 0;
}
.dna-panel-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.dna-badge-sim {
  font-size: 10px; font-family: var(--mono); font-weight: 700;
  padding: 1px 7px; border-radius: 10px;
  background: rgba(6,182,212,0.12); color: #06b6d4;
  border: 1px solid rgba(6,182,212,0.22);
  cursor: default;
}
.dna-badge-count {
  font-size: 10px; color: var(--muted);
  padding: 1px 6px; border-radius: 8px;
  background: rgba(255,255,255,0.04); border: 1px solid var(--border2);
}

/* Stats row */
.dna-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-bottom: 8px;
}
.dna-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 5px 4px;
  border-radius: var(--r-sm);
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
}
.dna-stat-label { font-size: 9.5px; color: var(--muted); text-align: center; }
.dna-stat-val   { font-size: 11.5px; font-weight: 700; font-family: var(--mono); text-align: center; color: var(--text); }
.dna-stat-green { color: var(--green) !important; }
.dna-stat-yellow{ color: var(--yellow) !important; }
.dna-stat-red   { color: var(--red) !important; }

/* Bias cell */
.dna-bias .dna-stat-val { font-family: var(--font); font-size: 10.5px; }
.dna-bias-bull { border-color: var(--green-border) !important; background: rgba(34,197,94,0.06) !important; }
.dna-bias-bull .dna-stat-val { color: var(--green); }
.dna-bias-bear { border-color: var(--red-border)   !important; background: rgba(239,68,68,0.06)  !important; }
.dna-bias-bear .dna-stat-val { color: var(--red); }
.dna-bias-neutral .dna-stat-val { color: var(--muted); }

/* Adjustment */
.dna-adj {
  font-size: 11.5px; font-weight: 600;
  padding: 5px 8px; border-radius: var(--r-sm); margin-bottom: 8px;
}
.dna-adj-pos     { background: rgba(34,197,94,0.08);  color: var(--green);  border: 1px solid rgba(34,197,94,0.2); }
.dna-adj-neg     { background: rgba(239,68,68,0.08);  color: var(--red);    border: 1px solid rgba(239,68,68,0.2); }
.dna-adj-neutral { background: rgba(87,99,126,0.08);  color: var(--muted);  border: 1px solid var(--border); }

/* Factor chips */
.dna-factors { display: flex; flex-direction: column; gap: 7px; margin-bottom: 8px; }
.dna-factor-group {}
.dna-factor-title {
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.05em; margin-bottom: 5px;
}
.dna-factor-title-pos  { color: rgba(34,197,94,0.75); }
.dna-factor-title-weak { color: rgba(87,99,126,0.9); }

.dna-chips { display: flex; flex-wrap: wrap; gap: 5px; }
.dna-chip {
  display: inline-flex; align-items: center;
  padding: 3px 9px; border-radius: 20px;
  font-size: 10.5px; font-weight: 600;
  cursor: default;
}
.dna-chip-pos  { background: rgba(6,182,212,0.1); color: #06b6d4; border: 1px solid rgba(6,182,212,0.22); }
.dna-chip-weak { background: rgba(87,99,126,0.1); color: var(--muted); border: 1px solid var(--border2); }

/* Top matches */
.dna-matches-section { margin-bottom: 8px; }
.dna-matches-toggle {
  display: flex; align-items: center; justify-content: space-between; width: 100%;
  background: rgba(255,255,255,0.03); border: 1px solid var(--border);
  border-radius: var(--r-sm); padding: 5px 9px;
  font-size: 10.5px; font-weight: 600; color: var(--muted);
  cursor: pointer; transition: background 0.15s;
}
.dna-matches-toggle:hover { background: rgba(255,255,255,0.06); color: var(--text); }
.dna-matches-chevron { font-size: 9px; margin-left: 4px; }

.dna-matches-list {
  margin-top: 4px;
  display: flex; flex-direction: column; gap: 2px;
}
.dna-match-row {
  display: grid;
  grid-template-columns: 16px 72px 82px 40px 62px 1fr;
  align-items: center;
  gap: 6px;
  padding: 4px 8px;
  border-radius: var(--r-sm);
  font-size: 10.5px;
  font-family: var(--mono);
  border: 1px solid transparent;
}
.dna-match-win  { background: rgba(34,197,94,0.05);  border-color: rgba(34,197,94,0.12); }
.dna-match-loss { background: rgba(239,68,68,0.05);  border-color: rgba(239,68,68,0.12); }
.dna-match-outcome { font-weight: 700; }
.dna-match-win  .dna-match-outcome { color: var(--green); }
.dna-match-loss .dna-match-outcome { color: var(--red); }
.dna-match-sym  { font-weight: 600; color: var(--text); font-family: var(--font); }
.dna-match-date { color: var(--muted); }
.dna-match-sim  { color: #06b6d4; font-weight: 600; }
.dna-match-move { font-weight: 600; }
.dna-match-regime { color: var(--muted2); font-family: var(--font); font-size: 10px; }

/* Summary */
.dna-summary {
  font-size: 11px; color: rgba(221,227,242,0.6); font-style: italic;
  border-top: 1px solid rgba(6,182,212,0.1);
  padding-top: 7px; margin-top: 2px; line-height: 1.5;
}

@media (max-width: 600px) {
  .dna-panel { padding: 8px 10px; }
  .dna-stats { grid-template-columns: repeat(2, 1fr); }
  .dna-chip  { font-size: 10px; padding: 2px 7px; }
  .dna-match-row { grid-template-columns: 16px 1fr 1fr 36px 54px; font-size: 9.5px; }
  .dna-match-regime { display: none; }
}

/* ── Hero Signal Card ────────────────────────────────────────────────────────── */

/* Outer wrapper — houses both the glow layer and the card */
.hero-sig-wrap { position:relative; margin-bottom:24px; }

/* Pulsing aura behind the card */
.hero-sig-glow {
  position:absolute; inset:-3px; border-radius:22px;
  z-index:0; pointer-events:none;
  animation:hero-glow-pulse 3.6s ease-in-out infinite;
}
.hs-long   .hero-sig-glow { background:radial-gradient(ellipse at 50% -10%, rgba(34,197,94,0.26) 0%, transparent 62%); }
.hs-short  .hero-sig-glow { background:radial-gradient(ellipse at 50% -10%, rgba(59,130,246,0.26) 0%, transparent 62%); }
.hs-neutral .hero-sig-glow{ background:radial-gradient(ellipse at 50% -10%, rgba(245,197,24,0.2) 0%, transparent 62%); }

/* The card itself */
.hero-sig {
  position:relative; z-index:1;
  border-radius:18px; padding:28px 28px 22px; overflow:hidden;
}
.hs-long   .hero-sig { background:linear-gradient(148deg,#0d1c14 0%,#0f1520 58%,#111520 100%); border:1px solid rgba(34,197,94,0.32); box-shadow:0 8px 48px rgba(34,197,94,0.07),inset 0 1px 0 rgba(34,197,94,0.1); }
.hs-short  .hero-sig { background:linear-gradient(148deg,#0d1422 0%,#0f1520 58%,#111520 100%); border:1px solid rgba(59,130,246,0.30); box-shadow:0 8px 48px rgba(59,130,246,0.07),inset 0 1px 0 rgba(59,130,246,0.1); }
.hs-neutral .hero-sig{ background:linear-gradient(148deg,#181500 0%,#0f1520 58%,#111520 100%); border:1px solid rgba(245,197,24,0.24); box-shadow:0 8px 48px rgba(245,197,24,0.05),inset 0 1px 0 rgba(245,197,24,0.07); }

/* Animated shimmer line across the top */
.hero-sig::before { content:''; position:absolute; top:0;left:0;right:0;height:2px; animation:hero-shimmer 3.6s ease-in-out infinite; }
.hs-long   .hero-sig::before { background:linear-gradient(90deg,transparent 0%,rgba(34,197,94,0.7) 28%,#22c55e 50%,rgba(34,197,94,0.7) 72%,transparent 100%); }
.hs-short  .hero-sig::before { background:linear-gradient(90deg,transparent 0%,rgba(59,130,246,0.7) 28%,#3b82f6 50%,rgba(59,130,246,0.7) 72%,transparent 100%); }
.hs-neutral .hero-sig::before{ background:linear-gradient(90deg,transparent 0%,rgba(245,197,24,0.7) 28%,#f5c518 50%,rgba(245,197,24,0.7) 72%,transparent 100%); }

/* Tag line */
.hero-sig-tag { font-size:10.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:8px; }
.hs-long   .hero-sig-tag { color:rgba(34,197,94,0.75); }
.hs-short  .hero-sig-tag { color:rgba(59,130,246,0.75); }
.hs-neutral .hero-sig-tag { color:rgba(245,197,24,0.75); }

/* Symbol + header row */
.hero-sig-head { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; margin-bottom:22px; }
.hero-sig-symbol { font-size:2rem; font-weight:900; letter-spacing:-0.03em; line-height:1.1; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.hero-sig-price { font-family:var(--mono); font-size:1.35rem; font-weight:700; text-align:right; flex-shrink:0; }

/* Body: score ring + meta */
.hero-sig-body { display:flex; align-items:center; gap:22px; margin-bottom:14px; }

/* Score ring — pulsing heartbeat */
.hero-sig-ring-wrap { flex-shrink:0; animation:score-beat 2.8s ease-in-out infinite; }
.hero-sig-ring { width:90px;height:90px;border-radius:50%; display:flex;flex-direction:column;align-items:center;justify-content:center; }
.hs-long   .hero-sig-ring { border:2px solid rgba(34,197,94,0.48);  background:radial-gradient(circle,rgba(34,197,94,0.12) 0%,transparent 68%); }
.hs-short  .hero-sig-ring { border:2px solid rgba(59,130,246,0.48); background:radial-gradient(circle,rgba(59,130,246,0.12) 0%,transparent 68%); }
.hs-neutral .hero-sig-ring{ border:2px solid rgba(245,197,24,0.42); background:radial-gradient(circle,rgba(245,197,24,0.09) 0%,transparent 68%); }

.hero-sig-score { font-family:var(--mono); font-size:2.1rem; font-weight:900; line-height:1; }
.hs-long   .hero-sig-score  { color:var(--green); }
.hs-short  .hero-sig-score  { color:var(--blue); }
.hs-neutral .hero-sig-score { color:var(--yellow); }
.hero-sig-score-sub { font-size:9px; color:var(--muted); text-transform:uppercase; letter-spacing:0.1em; margin-top:2px; }

/* Meta column */
.hero-sig-meta { flex:1; display:flex; flex-direction:column; gap:8px; min-width:0; }
.hero-sig-callout { font-size:12px; font-weight:600; color:var(--muted); padding:7px 11px; background:rgba(255,255,255,0.03); border:1px solid var(--border); border-radius:var(--r-sm); }
.hero-sig-desc { font-size:13px; color:rgba(221,227,242,0.82); line-height:1.6; }

/* Why bullets */
.hero-sig-why { border-top:1px solid var(--border); padding-top:12px; margin-top:6px; display:flex; flex-direction:column; gap:4px; }
.hero-sig-why-item { font-size:12px; color:var(--muted); }

/* Triggers */
.hero-sig-triggers { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:14px; }
.hero-sig-trigger { padding:9px 12px; border-radius:var(--r-sm); display:flex; flex-direction:column; gap:3px; }
.hero-sig-trigger-label { font-size:9.5px; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; opacity:0.7; }
.hero-sig-trigger-val { font-family:var(--mono); font-size:1.1rem; font-weight:800; }
.hero-sig-t-long  { background:var(--green-dim); border:1px solid var(--green-border); color:var(--green); }
.hero-sig-t-short { background:var(--red-dim);   border:1px solid var(--red-border);   color:var(--red); }

/* Footer */
.hero-sig-footer { display:flex; gap:8px; flex-wrap:wrap; margin-top:16px; padding-top:14px; border-top:1px solid var(--border); }

/* Secondary signals label + grid */
.hero-secondary-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--muted); margin:4px 0 12px; }

/* Empty state — no strong signal */
.hero-empty { display:flex; align-items:center; gap:16px; background:var(--surface2); border:1px solid var(--border); border-radius:var(--r); padding:22px 24px; }
.hero-empty-icon { font-size:26px; flex-shrink:0; opacity:0.35; }
.hero-empty-text { color:var(--muted); font-size:13px; line-height:1.55; }
.hero-empty-text strong { color:var(--text); display:block; margin-bottom:4px; font-size:14px; }

/* ── Animations ──────────────────────────────────────────────────────────────── */
@keyframes hero-glow-pulse {
  0%, 100% { opacity:0.65; }
  50%       { opacity:1; }
}
@keyframes hero-shimmer {
  0%, 100% { opacity:0.45; }
  50%       { opacity:1; }
}
@keyframes score-beat {
  0%,  100% { transform:scale(1); }
  14%        { transform:scale(1.06); }
  28%        { transform:scale(1); }
  44%        { transform:scale(1.03); }
  58%        { transform:scale(1); }
}

/* Respect reduced-motion preference */
@media (prefers-reduced-motion: reduce) {
  .hero-sig-glow, .hero-sig-ring-wrap { animation:none !important; }
  .hero-sig::before { animation:none !important; opacity:0.6; }
}

/* ── Hero Toast Notifications ────────────────────────────────────────────────── */

/* Container — fixed bottom-right, stacks toasts */
.hero-toast-wrap {
  position: fixed;
  bottom: 24px;
  right: 20px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;   /* clicks pass through gaps between toasts */
}

/* Individual toast */
.hero-toast {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: #0f1c14;
  border: 1px solid rgba(34,197,94,0.35);
  border-radius: 12px;
  padding: 14px 40px 14px 14px;
  min-width: 240px;
  max-width: 300px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(34,197,94,0.12);
  pointer-events: all;
  overflow: hidden;
  animation: toast-slide-in 0.28s cubic-bezier(0.34,1.2,0.64,1) both;
}

/* Lightning icon */
.hero-toast-icon {
  font-size: 1.3rem;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 1px;
  filter: drop-shadow(0 0 4px rgba(34,197,94,0.6));
}

/* Text body */
.hero-toast-body { flex: 1; min-width: 0; }
.hero-toast-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(34,197,94,0.75);
  margin-bottom: 3px;
}
.hero-toast-symbol {
  font-size: 1.1rem;
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--text);
  line-height: 1.1;
}
.hero-toast-meta {
  font-size: 11px;
  color: var(--muted);
  margin-top: 3px;
  font-family: var(--mono);
}

/* Dismiss button */
.hero-toast-close {
  position: absolute;
  top: 8px;
  right: 10px;
  width: 22px;
  height: 22px;
  border: none;
  background: none;
  color: var(--muted);
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.15s, background 0.15s;
}
.hero-toast-close:hover { color: var(--text); background: rgba(255,255,255,0.06); }

/* Progress bar — shrinks across the bottom */
.hero-toast-bar {
  position: absolute;
  bottom: 0; left: 0;
  height: 2px;
  width: 100%;
  background: linear-gradient(90deg, var(--green), rgba(34,197,94,0.3));
  transform-origin: left;
  animation: toast-bar-shrink linear both;
}

/* Slide-in animation */
@keyframes toast-slide-in {
  from { opacity: 0; transform: translateX(24px) scale(0.96); }
  to   { opacity: 1; transform: translateX(0) scale(1); }
}

/* Progress bar shrink */
@keyframes toast-bar-shrink {
  from { transform: scaleX(1); }
  to   { transform: scaleX(0); }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .hero-toast          { animation: none; }
  .hero-toast-bar      { animation: none; display: none; }
}

/* Mobile: full-width at bottom */
@media (max-width: 480px) {
  .hero-toast-wrap { right: 10px; left: 10px; bottom: 16px; }
  .hero-toast      { min-width: unset; max-width: unset; }
}

/* Responsive */
@media (max-width: 640px) {
  .hero-sig { padding:20px 18px 18px; }
  .hero-sig-body { flex-direction:column; align-items:flex-start; gap:14px; }
  .hero-sig-ring-wrap { align-self:center; }
  .hero-sig-triggers { grid-template-columns:1fr; }
  .hero-sig-symbol { font-size:1.6rem; }
  .hero-sig-price  { font-size:1.1rem; }
}

/* ── No-runs-yet placeholder ─────────────────────────────────────────────────── */
.rpl-no-runs {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 18px 20px;
  color: var(--muted);
  font-size: 13px;
  margin-bottom: 20px;
}
.rpl-no-runs-icon { font-size: 22px; }
.rpl-no-runs-text strong { color: var(--text); }

/* ── Responsive replay ───────────────────────────────────────────────────────── */
@media (max-width: 860px) {
  .rpl-form-grid { grid-template-columns: 1fr 1fr; }
  .rpl-form-group-wide { grid-column: span 2; }
}
@media (max-width: 640px) {
  .rpl-runs-list      { grid-template-columns: 1fr; }
  .rpl-summary-strip  { grid-template-columns: repeat(2, 1fr); }
  .rpl-sym-ranking    { grid-template-columns: 1fr; }
  .rpl-form-grid      { grid-template-columns: 1fr; }
  .rpl-form-group-wide { grid-column: span 1; }
}

/* ══════════════════════════════════════════════════════════════════════════════
   GLOBAL MOBILE RESPONSIVE — overrides all earlier partials
   ══════════════════════════════════════════════════════════════════════════════ */

/* ── Small tablet (≤ 768px) ─────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .page-wrap { padding: 20px 16px 48px; }
  .page-hero { gap: 10px; }
}

/* ── Phone (≤ 640px) ─────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  /* Page layout */
  .page-wrap  { padding: 14px 12px 40px; }
  .page-hero  { flex-direction: column; align-items: flex-start; padding-bottom: 14px; margin-bottom: 14px; }
  .hero-title { font-size: 1.25rem; }
  .hero-sub   { font-size: 11.5px; }
  .sec        { margin-bottom: 18px; }
  .sec-title  { font-size: 0.88rem; }

  /* Nav */
  .nav        { padding: 0 10px; height: 48px; gap: 6px; }
  .nav-brand  { font-size: 0.82rem; gap: 5px; }
  .nav-link   { padding: 0 9px; font-size: 11.5px; gap: 3px; }
  .btn-alert  { font-size: 10px; padding: 4px 8px; }

  /* Status bar */
  .status-bar-v2 { width: 100%; gap: 6px; }
  .status-pill   { font-size: 10px; padding: 2px 7px; }

  /* Summary strip — always 2×2 */
  .summary-strip { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .sum-card      { padding: 10px 8px; }
  .sum-card-count { font-size: 1.5rem; }
  .sum-card-label { font-size: 9px; }

  /* Guide */
  .guide-v2       { border-radius: var(--r-sm); }
  .guide-v2-body  { grid-template-columns: 1fr 1fr; gap: 8px; padding: 0 10px 12px; }
  .guide-item     { padding: 8px 10px; }
  .guide-item-icon { font-size: 1.1rem; }
  .guide-item-title { font-size: 11px; }
  .guide-item-desc  { font-size: 11px; }

  /* SymbolCard */
  .symbol-card        { padding: 12px; }
  .symbol-card-footer { flex-wrap: wrap; gap: 6px; }
  .symbol-card-actions { gap: 4px; }
  .sym-name           { font-size: 0.95rem; }

  /* BestCardV2 */
  .best-card-v2  { padding: 16px; }
  .bc-symbol     { font-size: 1.2rem; }
  .bc-price      { font-size: 0.95rem; }
  .bc-triggers   { grid-template-columns: 1fr; }
  .bc-actions    { gap: 4px; flex-wrap: wrap; }

  /* Hero signal */
  .hero-sig          { padding: 20px 16px 16px; }
  .hero-sig-symbol   { font-size: 1.55rem; }
  .hero-sig-price    { font-size: 1.1rem; }
  .hero-sig-body     { flex-direction: column; align-items: flex-start; gap: 14px; }
  .hero-sig-ring-wrap { align-self: center; }
  .hero-sig-meta     { width: 100%; }
  .hero-sig-triggers { grid-template-columns: 1fr; }

  /* HealthChips */
  .health-chips { gap: 4px; }
  .health-chip  { min-width: 44px; padding: 3px 6px; }
  .chip-label   { font-size: 8px; }
  .chip-value   { font-size: 10px; }

  /* WhyBox */
  .why-box { padding: 8px 10px; }

  /* Confidence */
  .conf-score-delta { font-size: 10.5px; }
  .conf-panel       { padding: 8px 10px; }

  /* AutoFilter banner */
  .af-banner { padding: 8px 10px; gap: 7px; }

  /* Tables */
  .table-wrap table { min-width: 760px; }

  /* QQQ premium */
  .qqq-prem-grid  { grid-template-columns: repeat(2, 1fr); }
  .qqq-prem-price { font-size: 1.2rem; }
  .qqq-prem-sym   { font-size: 1.1rem; }

  /* Historik */
  .hist-stats-strip { grid-template-columns: repeat(2, 1fr); gap: 8px; }

  /* Replay */
  .rpl-runs-list     { grid-template-columns: 1fr; }
  .rpl-summary-strip { grid-template-columns: repeat(2, 1fr); }
}

/* ── Small phone (≤ 480px) ───────────────────────────────────────────────────── */
@media (max-width: 480px) {
  /* Nav: icons only, no label text */
  .nav                  { padding: 0 6px; gap: 0; }
  .nav-link             { padding: 0 7px; }
  .nav-link span:last-child { display: none; }   /* hide "Aktier", "Nasdaq" etc. */
  .btn-alert            { display: none; }        /* hide alert button — saves space */

  /* Page */
  .page-wrap  { padding: 12px 10px 32px; }
  .hero-title { font-size: 1.1rem; }
  .hero-sub   { font-size: 11px; }
  .sec-title  { font-size: 0.82rem; }

  /* Summary strip stays 2×2 */
  .sum-card-count { font-size: 1.35rem; }
  .sum-card-icon  { font-size: 1rem; }

  /* Guide: single column */
  .guide-v2-body { grid-template-columns: 1fr; }

  /* Hero signal */
  .hero-sig        { padding: 16px 12px 14px; }
  .hero-sig-symbol { font-size: 1.35rem; }
  .hero-sig-ring   { width: 76px; height: 76px; }
  .hero-sig-score  { font-size: 1.6rem; }
  .hero-sig-callout { font-size: 11px; padding: 6px 9px; }
  .hero-sig-desc   { font-size: 12px; }

  /* BestCardV2 */
  .best-card-v2  { padding: 14px 12px; }
  .bc-symbol     { font-size: 1.05rem; }

  /* SymbolCard */
  .symbol-card { padding: 10px 10px; }

  /* Score meter */
  .score-meter-num { font-size: 12px; }
  .score-meter-tag { font-size: 9px; }

  /* Badges — slightly smaller */
  .badge        { font-size: 9.5px; padding: 2px 6px; }
  .conf-label   { font-size: 9px; padding: 1px 6px; }

  /* Buttons */
  .btn { font-size: 10.5px; padding: 4px 8px; }
  .btn-tv { font-size: 10.5px; }
}

/* ── Auto-Machine page (/machine) ──────────────────────────────────────────── */

.nav-machine:hover  { color: var(--blue); }
.nav-machine.active { color: var(--blue); border-bottom-color: var(--blue); }

/* Status row */
.mc-status-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.mc-status-card {
  flex: 1 1 140px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 12px 14px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.mc-status-card-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 600;
}
.mc-status-card-val {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 6px;
}
.mc-status-mono { font-family: var(--mono); font-size: 0.78rem; }
.mc-status-running { color: var(--yellow); }
.mc-status-idle    { color: var(--green); }

/* Stat strip */
.mc-stat-strip {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}
.mc-stat-card {
  flex: 1 1 120px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 14px 14px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  text-align: center;
}
.mc-stat-icon  { font-size: 1.4rem; line-height: 1; }
.mc-stat-val   { font-size: 1.25rem; font-weight: 800; font-family: var(--mono); color: var(--text); }
.mc-stat-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }

/* Pipeline */
.mc-pipeline {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  overflow: hidden;
}
.mc-step {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 18px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}
.mc-step:last-child { border-bottom: none; }
.mc-step-active { background: rgba(59,130,246,0.06); }
.mc-step-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.mc-step-icon  { font-size: 1.1rem; width: 24px; text-align: center; }
.mc-step-info  { display: flex; flex-direction: column; gap: 2px; }
.mc-step-label { font-size: 0.85rem; font-weight: 700; color: var(--text); }
.mc-step-desc  { font-size: 11px; color: var(--muted); }
.mc-step-right {
  display: flex;
  align-items: center;
  gap: 10px;
}
.mc-step-detail {
  font-size: 11px;
  color: var(--muted);
  font-family: var(--mono);
}
.mc-step-detail-warn { color: var(--orange); }
.mc-step-detail-err  { color: var(--red); }
.mc-step-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  font-size: 11px;
  font-weight: 800;
  flex-shrink: 0;
}
.mc-step-ok      { background: var(--green-dim);   color: var(--green);  border: 1px solid var(--green-border); }
.mc-step-err     { background: var(--red-dim);     color: var(--red);    border: 1px solid var(--red-border); }
.mc-step-pending { background: var(--yellow-dim);  color: var(--yellow); border: 1px solid var(--yellow-border); }
.mc-step-idle    { background: var(--surface2);    color: var(--muted);  border: 1px solid var(--border2); }
.mc-spinner { width: 10px !important; height: 10px !important; }

/* Run form */
.mc-run-form {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 20px 22px;
}
.mc-run-form::before {
  content: '';
  display: block;
  height: 3px;
  background: linear-gradient(90deg, var(--blue), var(--purple));
  border-radius: var(--r) var(--r) 0 0;
  margin: -20px -22px 16px;
}
.mc-run-form-title {
  font-size: 0.88rem;
  font-weight: 800;
  color: var(--text);
  margin-bottom: 16px;
}
.mc-running-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--yellow-dim);
  border: 1px solid var(--yellow-border);
  border-radius: var(--r-sm);
  padding: 10px 14px;
  font-size: 13px;
  color: var(--yellow);
  margin-bottom: 16px;
}
.mc-form-body    { display: flex; flex-direction: column; gap: 16px; }
.mc-form-row     { display: flex; gap: 24px; flex-wrap: wrap; }
.mc-form-group   { display: flex; flex-direction: column; gap: 8px; }
.mc-form-label   { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.mc-checkboxes   { display: flex; gap: 10px; flex-wrap: wrap; }
.mc-checkbox {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border: 1px solid var(--border2);
  border-radius: var(--r-sm);
  cursor: pointer;
  font-size: 13px;
  color: var(--muted);
  background: var(--surface);
  transition: border-color 0.15s, color 0.15s, background 0.15s;
  user-select: none;
}
.mc-checkbox input { position: absolute; opacity: 0; pointer-events: none; }
.mc-checkbox:hover    { border-color: var(--blue-border); color: var(--text); }
.mc-cb-active         { border-color: var(--blue-border); background: var(--blue-dim); color: var(--blue); }
.mc-cb-hint {
  font-size: 9.5px;
  color: var(--muted);
  font-family: var(--mono);
  margin-left: 2px;
}
.mc-cb-active .mc-cb-hint { color: var(--blue); opacity: 0.7; }
.mc-lookback-options { display: flex; gap: 8px; }
.mc-lb-btn {
  padding: 6px 16px;
  border: 1px solid var(--border2);
  border-radius: var(--r-sm);
  background: var(--surface);
  color: var(--muted);
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.15s;
  font-family: var(--mono);
}
.mc-lb-btn:hover    { border-color: var(--blue-border); color: var(--text); }
.mc-lb-active       { border-color: var(--blue-border); background: var(--blue-dim); color: var(--blue); }
.mc-lb-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.mc-form-actions    { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.mc-run-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 24px;
  background: linear-gradient(135deg, var(--blue), var(--purple));
  color: #fff;
  border: none;
  border-radius: var(--r-sm);
  font-size: 14px;
  font-weight: 800;
  cursor: pointer;
  transition: opacity 0.15s;
  letter-spacing: -0.01em;
}
.mc-run-btn:hover:not(:disabled) { opacity: 0.88; }
.mc-run-btn:disabled, .mc-run-btn-busy { opacity: 0.6; cursor: not-allowed; }
.mc-form-ok  { font-size: 12px; color: var(--green); }
.mc-form-error {
  background: var(--red-dim);
  border: 1px solid var(--red-border);
  border-radius: var(--r-sm);
  padding: 8px 12px;
  font-size: 12px;
  color: var(--red);
}

/* Config note */
.mc-config-note {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 10px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  font-size: 11.5px;
  color: var(--muted);
  margin-top: 8px;
}
.mc-config-note-icon { flex-shrink: 0; }
.mc-config-note code {
  font-family: var(--mono);
  font-size: 10.5px;
  background: var(--surface3);
  padding: 1px 4px;
  border-radius: 3px;
  color: var(--text);
}

/* Scheduler panel */
.mc-sched-panel {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  overflow: hidden;
}
.mc-sched-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px 12px;
  border-bottom: 1px solid var(--border);
}
.mc-sched-title { font-size: 0.88rem; font-weight: 800; color: var(--text); }
.mc-sched-pill {
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid;
}
.mc-sched-on  { color: var(--green);  border-color: var(--green-border);  background: var(--green-dim); }
.mc-sched-off { color: var(--orange); border-color: var(--orange-border); background: var(--orange-dim); }
.mc-sched-warn {
  margin: 0 18px 0;
  padding: 10px 14px;
  background: var(--orange-dim);
  border: 1px solid var(--orange-border);
  border-radius: var(--r-sm);
  font-size: 12px;
  color: var(--orange);
  margin-top: 14px;
}
.mc-sched-warn code, .mc-sched-ok code, .mc-sched-env-note code {
  font-family: var(--mono);
  font-size: 10.5px;
  background: rgba(0,0,0,0.25);
  padding: 1px 4px;
  border-radius: 3px;
}
.mc-sched-ok {
  margin: 14px 18px 0;
  padding: 10px 14px;
  background: var(--green-dim);
  border: 1px solid var(--green-border);
  border-radius: var(--r-sm);
  font-size: 12px;
  color: var(--green);
}
.mc-sched-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
  padding: 14px 18px;
}
.mc-sched-item {
  flex: 1 1 160px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 8px 12px;
  border-right: 1px solid var(--border);
}
.mc-sched-item:last-child { border-right: none; }
.mc-sched-item-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}
.mc-sched-item-val {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--text);
  font-family: var(--mono);
}
.mc-sched-env-note {
  padding: 10px 18px;
  font-size: 10.5px;
  color: var(--muted);
  border-top: 1px solid var(--border);
  background: var(--surface);
  line-height: 1.6;
}

@media (max-width: 600px) {
  .mc-status-row { gap: 8px; }
  .mc-status-card { flex: 1 1 100%; }
  .mc-stat-strip  { gap: 8px; }
  .mc-stat-card   { flex: 1 1 80px; }
  .mc-form-row    { flex-direction: column; gap: 16px; }
  .mc-step        { flex-direction: column; align-items: flex-start; gap: 8px; }
  .mc-step-right  { align-self: flex-end; }
  .mc-sched-item  { border-right: none; border-bottom: 1px solid var(--border); }
}

/* ── Missed Breakouts nav ────────────────────────────────────────────────────── */
.nav-missed       { color: var(--muted); }
.nav-missed:hover { color: #a78bfa; }
.nav-missed.active { color: #a78bfa; border-bottom-color: #a78bfa; }

/* ── Missed Breakouts page ───────────────────────────────────────────────────── */
.mb-stats-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 20px;
  padding: 14px 16px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
}
.mb-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 80px;
}
.mb-stat-wide { flex: 1 1 200px; }
.mb-stat-val {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.1;
}
.mb-stat-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-stat-reason {
  font-size: 11px;
  color: var(--muted);
  font-style: italic;
  margin-top: 2px;
}

/* Filter bar */
.mb-filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: flex-end;
  margin-bottom: 18px;
  padding: 12px 14px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r);
}
.mb-filter-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.mb-filter-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-filter-pills { display: flex; gap: 4px; }
.mb-pill {
  padding: 3px 10px;
  font-size: 11px;
  font-weight: 600;
  border-radius: var(--r-sm);
  border: 1px solid var(--border2);
  background: var(--surface3);
  color: var(--muted);
  cursor: pointer;
  transition: background 0.12s, color 0.12s;
}
.mb-pill:hover { color: var(--text); border-color: var(--muted2); }
.mb-pill-active { background: var(--surface); color: #a78bfa; border-color: #a78bfa; }
.mb-select {
  padding: 4px 8px;
  font-size: 12px;
  background: var(--surface3);
  color: var(--text);
  border: 1px solid var(--border2);
  border-radius: var(--r-sm);
  cursor: pointer;
}
.mb-checkbox-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--muted);
  cursor: pointer;
}

/* Grid */
.mb-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 14px;
}

/* Card */
.mb-card {
  position: relative;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px 14px 12px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow: hidden;
}
.mb-card-accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  border-radius: var(--r) 0 0 var(--r);
}
.mb-card-header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
}
.mb-card-sym {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
  font-family: var(--mono);
  margin-right: 4px;
}

/* Time */
.mb-time-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
}
.mb-time-label { color: var(--muted); }
.mb-time-val   { font-family: var(--mono); color: var(--text); }

/* Go to date row (reuses hist-tv-goto styles) */
.mb-tv-goto {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  font-size: 12px;
  padding: 5px 8px;
  background: color-mix(in srgb, #2962FF 8%, transparent);
  border: 1px solid color-mix(in srgb, #2962FF 18%, transparent);
  border-radius: var(--r-sm);
}

/* System said */
.mb-system-said {
  background: var(--surface3);
  border-radius: var(--r-sm);
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.mb-section-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-bottom: 2px;
}
.mb-action { font-size: 13px; font-weight: 600; color: var(--text); }
.mb-reason { font-size: 11px; color: var(--muted); line-height: 1.4; }

/* What happened */
.mb-happened {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.mb-happened-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
}
.mb-happened-label { color: var(--muted); min-width: 140px; }
.mb-happened-max   { color: var(--muted); font-size: 11px; }

/* Continuation bar */
.mb-continuation-bar-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 2px;
}
.mb-cont-label { font-size: 10px; color: var(--muted); min-width: 120px; }
.mb-cont-bar-bg {
  flex: 1;
  height: 5px;
  background: var(--border2);
  border-radius: 2px;
  overflow: hidden;
}
.mb-cont-bar-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.3s;
}
.mb-cont-val {
  font-size: 11px;
  font-family: var(--mono);
  color: var(--muted);
  min-width: 24px;
  text-align: right;
}

/* Scores */
.mb-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.mb-score-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 60px;
}
.mb-score-label { font-size: 10px; color: var(--muted); }
.mb-score-val   { font-size: 14px; font-weight: 700; color: var(--text); }

/* Review summary */
.mb-review-summary {
  font-size: 12px;
  color: var(--muted);
  font-style: italic;
  line-height: 1.4;
  padding: 6px 8px;
  background: var(--surface3);
  border-radius: var(--r-sm);
  border-left: 2px solid var(--border2);
}

@media (max-width: 600px) {
  .mb-grid { grid-template-columns: 1fr; }
  .mb-filter-bar { gap: 10px; }
}

/* ── Wave Page ───────────────────────────────────────────────────────────────── */

.wave-accent { color: #38bdf8; }
.hero-accent-wave { color: #38bdf8; }

.nav-wave { color: var(--muted); }
.nav-wave:hover { color: #38bdf8; }
.nav-wave.active { color: #38bdf8; border-bottom-color: #38bdf8; }

.wave-hero-right { display:flex; align-items:center; gap:10px; }
.wave-refresh-btn { background:var(--surface2); border:1px solid var(--border2); color:var(--muted); padding:6px 14px; border-radius:var(--r-sm); font-size:12px; cursor:pointer; }
.wave-refresh-btn:hover { background:var(--surface3); color:var(--text); }
.wave-active-badge { background:rgba(56,189,248,0.12); border:1px solid rgba(56,189,248,0.3); color:#38bdf8; padding:4px 10px; border-radius:var(--r-sm); font-size:11px; font-weight:700; }

.wave-error { background:var(--red-dim); border:1px solid var(--red-border); color:var(--red); padding:12px 16px; border-radius:var(--r); margin-bottom:20px; }
.wave-loading { text-align:center; color:var(--muted); padding:40px 0; }
.wave-empty { text-align:center; color:var(--muted); padding:40px 0; background:var(--surface); border:1px solid var(--border); border-radius:var(--r); }

/* Phase sections */
.wave-section { margin-bottom:32px; }
.wave-section-header { display:flex; align-items:center; gap:10px; margin-bottom:6px; padding-bottom:8px; border-bottom:1px solid var(--border); }
.wave-section-icon { font-size:1.2rem; }
.wave-section-title { font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:0.07em; color:var(--text); }
.wave-section-count { font-size:0.85rem; color:var(--muted); }
.wave-section-hint { font-size:12px; color:var(--muted); margin-bottom:12px; line-height:1.5; }

/* Grid */
.wave-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:12px; }

/* Cards */
.wave-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: border-color 0.2s;
}
.wave-card:hover { border-color: var(--border2); }

.wave-compression  { border-left: 3px solid var(--yellow); }
.wave-impulse-start { border-left: 3px solid var(--green); }
.wave-continuation { border-left: 3px solid var(--blue); }
.wave-pullback     { border-left: 3px solid var(--orange); }
.wave-exhaustion   { border-left: 3px solid var(--red); }
.wave-choppy       { border-left: 3px solid var(--border2); }

.wave-card-header { display:flex; flex-direction:column; gap:5px; }
.wave-card-top { display:flex; justify-content:space-between; align-items:baseline; }
.wave-card-symbol { font-size:1rem; font-weight:800; letter-spacing:-0.01em; }
.wave-card-price { font-size:0.9rem; font-weight:600; color:var(--muted); font-family:var(--mono); }
.wave-card-badges { display:flex; flex-wrap:wrap; gap:5px; align-items:center; }
.wave-num-badge { font-family:var(--mono); font-size:10px; }

.wave-dir { font-size:10.5px; font-weight:700; padding:2px 7px; border-radius:var(--r-sm); border:1px solid; }
.wave-dir-up      { background:var(--green-dim);  color:var(--green);  border-color:var(--green-border); }
.wave-dir-down    { background:var(--red-dim);    color:var(--red);    border-color:var(--red-border); }
.wave-dir-neutral { background:var(--surface2);   color:var(--muted);  border-color:var(--border2); }

/* Confidence bar */
.wave-conf-bar { display:flex; align-items:center; gap:8px; }
.wave-conf-track { flex:1; height:4px; background:var(--border2); border-radius:2px; overflow:hidden; }
.wave-conf-fill { height:100%; border-radius:2px; transition:width 0.4s; }
.wave-conf-num { font-family:var(--mono); font-size:11px; font-weight:700; min-width:32px; text-align:right; }

/* Summary */
.wave-summary { font-size:12px; color:var(--text); line-height:1.5; }

/* Risks */
.wave-risks { display:flex; gap:8px; flex-wrap:wrap; }
.wave-risk-dot { font-size:10.5px; font-weight:600; padding:2px 8px; border-radius:var(--r-sm); border:1px solid; }
.wave-risk-high { background:var(--red-dim);    color:var(--red);    border-color:var(--red-border); }
.wave-risk-med  { background:var(--yellow-dim); color:var(--yellow); border-color:var(--yellow-border); }
.wave-risk-low  { background:var(--surface2);   color:var(--muted);  border-color:var(--border2); }

/* Footer */
.wave-card-footer { display:flex; justify-content:space-between; align-items:center; margin-top:2px; }
.wave-expand-btn { background:none; border:none; color:var(--muted); font-size:11px; cursor:pointer; padding:2px 0; }
.wave-expand-btn:hover { color:var(--text); }
.wave-tv-btn { font-size:11px; padding:4px 10px; }

/* Details */
.wave-details { display:flex; flex-direction:column; gap:8px; padding-top:6px; border-top:1px solid var(--border); }
.wave-metrics { display:flex; flex-wrap:wrap; gap:5px; }
.wave-why { margin-top:0; }

@media (max-width: 600px) {
  .wave-grid { grid-template-columns: 1fr; }
}

/* ═══════════════════════════════════════════════════════════════
   DECISION ENGINE COMPONENTS
   ═══════════════════════════════════════════════════════════════ */

/* ── Decision Action Badge ───────────────────────────────────── */
.dec-action-badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 10.5px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
  padding: 3px 9px; border-radius: var(--r-sm); border: 1px solid;
}
.dab-buy       { background: var(--green-dim);   color: var(--green);   border-color: var(--green-border); }
.dab-sell      { background: var(--red-dim);     color: var(--red);     border-color: var(--red-border); }
.dab-confirmed { background: var(--green-dim);   color: var(--green);   border-color: var(--green-border); font-weight: 800; }
.dab-risk      { background: var(--yellow-dim);  color: var(--yellow);  border-color: var(--yellow-border); }
.dab-avoid     { background: var(--red-dim);     color: var(--red);     border-color: var(--red-border); opacity: .75; }
.dab-wait      { background: var(--surface2);    color: var(--muted);   border-color: var(--border2); }

/* ── Decision Risk Badge ─────────────────────────────────────── */
.dec-risk-badge {
  display: inline-flex; align-items: center;
  font-size: 10px; font-weight: 600; padding: 2px 7px;
  border-radius: var(--r-sm); border: 1px solid;
}
.drb-low  { background: var(--green-dim);  color: var(--green);  border-color: var(--green-border); }
.drb-high { background: var(--red-dim);    color: var(--red);    border-color: var(--red-border); }
.drb-med  { background: var(--yellow-dim); color: var(--yellow); border-color: var(--yellow-border); }

/* ── Decision Confidence Badge ───────────────────────────────── */
.dec-conf-badge {
  display: inline-flex; align-items: center;
  font-size: 10px; font-weight: 600; padding: 2px 7px;
  border-radius: var(--r-sm); border: 1px solid;
}
.dcb-high { background: var(--green-dim);  color: var(--green);  border-color: var(--green-border); }
.dcb-low  { background: var(--red-dim);    color: var(--red);    border-color: var(--red-border); }
.dcb-med  { background: var(--surface2);   color: var(--muted);  border-color: var(--border2); }

/* ── Why Decision Block ──────────────────────────────────────── */
.why-dec-block { display: flex; flex-direction: column; gap: 4px; }
.why-dec-row {
  display: flex; align-items: flex-start; gap: 6px;
  font-size: 12px; line-height: 1.45;
}
.why-dec-good { color: var(--green); flex-shrink: 0; }
.why-dec-bad  { color: var(--red);   flex-shrink: 0; }

/* ── History Says Block ──────────────────────────────────────── */
.hist-says-block {
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--r); padding: 10px 12px; display: flex; flex-direction: column; gap: 6px;
}
.hist-says-title { font-size: 11px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: .05em; }
.hist-says-summary { font-size: 12px; color: var(--text); line-height: 1.5; }
.hist-says-stats { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 2px; }
.hist-says-stat { display: flex; flex-direction: column; gap: 1px; }
.hss-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
.hss-val   { font-size: 13px; font-weight: 700; color: var(--text); font-family: var(--mono); }
.hist-says-regime {
  font-size: 11px; color: var(--muted); border-top: 1px solid var(--border);
  padding-top: 5px; margin-top: 2px;
}

/* ── Decision Hero Card ──────────────────────────────────────── */
.dec-hero-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r-lg); padding: 18px 20px;
  display: flex; flex-direction: column; gap: 12px;
}
.dec-hero-header { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.dec-hero-sym { font-size: 22px; font-weight: 800; color: var(--text); }
.dec-hero-price { font-size: 16px; font-weight: 600; font-family: var(--mono); color: var(--muted); }
.dec-hero-badges { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.dec-setup-type {
  font-size: 10.5px; font-weight: 600; color: var(--blue);
  background: var(--blue-dim, rgba(59,130,246,.12)); border: 1px solid rgba(59,130,246,.25);
  padding: 2px 8px; border-radius: var(--r-sm);
}
.dec-hero-score { font-size: 26px; font-weight: 800; font-family: var(--mono); color: var(--text); }
.dec-hero-score-label { font-size: 10px; color: var(--muted); }
.dec-hero-triggers { display: flex; gap: 8px; flex-wrap: wrap; }
.dec-hero-trigger {
  font-size: 11px; font-family: var(--mono); padding: 3px 8px;
  background: var(--surface2); border: 1px solid var(--border2); border-radius: var(--r-sm); color: var(--muted);
}
.dec-recommendation {
  background: var(--surface2); border-left: 3px solid var(--blue);
  padding: 9px 12px; border-radius: 0 var(--r) var(--r) 0;
}
.dec-rec-label { font-size: 10px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
.dec-rec-text  { font-size: 12.5px; color: var(--text); line-height: 1.5; }
.dec-hero-expand-btn {
  background: none; border: 1px solid var(--border2); color: var(--muted);
  font-size: 11px; cursor: pointer; padding: 4px 12px; border-radius: var(--r-sm); align-self: flex-start;
}
.dec-hero-expand-btn:hover { color: var(--text); border-color: var(--border); }
.dec-hero-regime-comment { font-size: 11px; color: var(--muted); margin-top: 4px; }

/* ── Top 5 Signals Section ───────────────────────────────────── */
.top5-section { display: flex; flex-direction: column; }
.top5-header {
  display: grid;
  grid-template-columns: 24px 80px 1fr 50px 60px 60px 40px 1fr 36px;
  gap: 6px; padding: 6px 10px;
  font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
  color: var(--muted); border-bottom: 1px solid var(--border);
}
.top5-row {
  display: grid;
  grid-template-columns: 24px 80px 1fr 50px 60px 60px 40px 1fr 36px;
  gap: 6px; padding: 8px 10px; align-items: center;
  border-bottom: 1px solid var(--border); font-size: 12.5px;
  transition: background .15s;
}
.top5-row:last-child { border-bottom: none; }
.top5-row:hover { background: var(--surface2); }
.top5-rank { font-size: 11px; font-weight: 700; color: var(--muted); text-align: center; }
.top5-sym  { font-weight: 700; color: var(--text); }
.top5-badges { display: flex; gap: 4px; flex-wrap: wrap; align-items: center; }
.top5-score { font-family: var(--mono); font-weight: 700; color: var(--text); }
.top5-conf  { }
.top5-wr    { font-family: var(--mono); font-size: 11.5px; color: var(--muted); }
.top5-tf    { font-family: var(--mono); font-size: 11px; color: var(--muted); }
.top5-reason { font-size: 11.5px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.top5-link  { }

@media (max-width: 700px) {
  .top5-header { display: none; }
  .top5-row {
    grid-template-columns: 24px 1fr auto auto auto;
    grid-template-rows: auto auto;
  }
  .top5-badges, .top5-wr, .top5-tf, .top5-reason { grid-column: span 2; font-size: 11px; }
}

/* ── Decision Filter Bar ─────────────────────────────────────── */
.dec-filter-bar {
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  padding: 10px 14px; background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 10px;
}
.dec-filter-modes { display: flex; gap: 4px; flex-wrap: wrap; }
.dec-filter-btn {
  background: var(--surface2); border: 1px solid var(--border2); color: var(--muted);
  font-size: 11.5px; font-weight: 600; padding: 4px 12px; border-radius: var(--r-sm); cursor: pointer;
  transition: all .15s;
}
.dec-filter-btn:hover { color: var(--text); border-color: var(--border); }
.dec-filter-btn.active {
  background: var(--blue-dim, rgba(59,130,246,.15)); color: var(--blue);
  border-color: rgba(59,130,246,.4);
}
.dec-filter-sep { width: 1px; height: 20px; background: var(--border2); }
.dec-filter-toggles { display: flex; gap: 10px; flex-wrap: wrap; }
.dec-filter-toggle {
  display: flex; align-items: center; gap: 5px;
  font-size: 11.5px; color: var(--muted); cursor: pointer; user-select: none;
}
.dec-filter-toggle input { cursor: pointer; }
.dec-filter-toggle:hover { color: var(--text); }

/* ── Symbol Group Card ───────────────────────────────────────── */
.sym-groups-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px;
}
.sym-group-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 14px 16px; display: flex; flex-direction: column; gap: 10px;
}
.sym-group-header { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
.sym-group-sym { font-size: 18px; font-weight: 800; color: var(--text); }
.sym-group-meta { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
.sym-group-stats { display: flex; gap: 10px; flex-wrap: wrap; }
.sym-group-stat { display: flex; flex-direction: column; gap: 1px; }
.sgs-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
.sgs-val   { font-size: 14px; font-weight: 700; font-family: var(--mono); color: var(--text); }
.sym-group-actions { display: flex; gap: 6px; flex-wrap: wrap; }
.sym-group-action-pill {
  font-size: 11px; padding: 2px 8px; border-radius: var(--r-sm);
  background: var(--surface2); border: 1px solid var(--border2); color: var(--muted);
}
.sym-group-hist { font-size: 11.5px; color: var(--muted); line-height: 1.5; }
.sym-group-signals { display: flex; flex-direction: column; gap: 4px; }
.sym-group-sig-row {
  display: flex; align-items: center; gap: 8px; padding: 5px 8px;
  background: var(--surface2); border-radius: var(--r-sm); font-size: 12px;
}
.sgs-sig-tf  { font-family: var(--mono); font-size: 10.5px; color: var(--muted); min-width: 18px; }
.sgs-sig-score { font-family: var(--mono); font-weight: 700; color: var(--text); margin-left: auto; }
.sgs-sig-reason { font-size: 11px; color: var(--muted); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── System Conclusion Box ───────────────────────────────────── */
.sys-conclusion-box {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r-lg); padding: 16px 18px; display: flex; flex-direction: column; gap: 12px;
  margin-bottom: 4px;
}
.sys-conc-title { font-size: 13px; font-weight: 700; color: var(--text); }
.sys-conc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; }
.sys-conc-item {
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--r); padding: 10px 12px; display: flex; flex-direction: column; gap: 3px;
}
.sci-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
.sci-val   { font-size: 16px; font-weight: 800; font-family: var(--mono); color: var(--text); }
.sci-sub   { font-size: 10.5px; color: var(--muted); }
.sci-dot   { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }
.sys-conc-insights { display: flex; flex-direction: column; gap: 5px; padding-top: 4px; border-top: 1px solid var(--border); }
.sys-conc-insight {
  display: flex; align-items: flex-start; gap: 7px; font-size: 12px; color: var(--text); line-height: 1.5;
}

/* ── Replay Run Rating ───────────────────────────────────────── */
.rpl-run-rating {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 700; padding: 3px 9px;
  border-radius: var(--r-sm); border: 1px solid;
}
.rpl-rating-good { background: var(--green-dim);  color: var(--green);  border-color: var(--green-border); }
.rpl-rating-ok   { background: var(--yellow-dim); color: var(--yellow); border-color: var(--yellow-border); }
.rpl-rating-bad  { background: var(--red-dim);    color: var(--red);    border-color: var(--red-border); }
.rpl-rating-few  { background: var(--surface2);   color: var(--muted);  border-color: var(--border2); }
.rpl-rating-label { font-weight: 800; }
.rpl-rating-desc  { font-weight: 400; opacity: .8; }

/* ── Replay Conclusion Box ───────────────────────────────────── */
.rpl-conclusion-box {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--r); padding: 14px 16px; display: flex; flex-direction: column; gap: 10px;
}
.rpl-conc-title { font-size: 12px; font-weight: 700; color: var(--text); }
.rpl-conc-grid { display: flex; gap: 14px; flex-wrap: wrap; }
.rpl-conc-item { display: flex; flex-direction: column; gap: 2px; }
.rpl-ci-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }
.rpl-ci-val   { font-size: 14px; font-weight: 700; color: var(--text); }
.rpl-ci-dot   { font-size: 12px; color: var(--muted); }
.rpl-conc-insights { display: flex; flex-direction: column; gap: 4px; border-top: 1px solid var(--border); padding-top: 6px; }
.rpl-conc-insight {
  display: flex; align-items: flex-start; gap: 6px; font-size: 12px; color: var(--muted); line-height: 1.5;
}

/* ── Hero empty state ────────────────────────────────────────── */
.hero-empty {
  display: flex; align-items: center; gap: 14px;
  padding: 18px 20px; background: var(--surface2);
  border: 1px dashed var(--border2); border-radius: var(--r);
}
.hero-empty-icon { font-size: 28px; flex-shrink: 0; }
.hero-empty-text { display: flex; flex-direction: column; gap: 3px; font-size: 13px; color: var(--muted); }
.hero-empty-text strong { color: var(--text); font-size: 14px; }

/* ══════════════════════════════════════════════════════════════
   MIXED MOVERS UI IMPROVEMENTS
   ══════════════════════════════════════════════════════════════ */

/* ── Top Signals Panel (improved) ───────────────────────────── */
.top-signals-panel { margin: 16px 0 20px; }
.top-signals-label {
  font-size: 10px; font-weight: 700; color: var(--muted);
  letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 10px;
}
.top-signals-grid {
  display: grid; gap: 10px;
}
.top-signal-mini {
  background: #0d1322; border: 1px solid var(--border2); border-radius: var(--r);
  padding: 14px 16px; display: flex; flex-direction: column; gap: 7px;
  height: 100%; transition: border-color 0.15s;
}
.top-signal-mini:hover { border-color: var(--border); }
.tsm-role { font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.tsm-head { display: flex; justify-content: space-between; align-items: center; }
.tsm-symbol { font-size: 26px; font-weight: 900; color: var(--text); letter-spacing: -0.03em; line-height: 1; }
.tsm-score { font-size: 20px; font-weight: 800; font-family: var(--mono); line-height: 1; }
.tsm-price { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--muted); }
.tsm-badges { display: flex; gap: 5px; flex-wrap: wrap; align-items: center; }
.tsm-trigger {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 10px; border-radius: var(--r-sm); border: 1px solid;
  font-size: 12.5px; font-weight: 700; font-family: var(--mono);
}
.tsm-trigger strong { font-size: 14px; }
.tsm-repeat-bias { display: flex; gap: 10px; font-size: 12.5px; font-weight: 700; }
.tsm-desc { font-size: 11px; color: var(--muted); line-height: 1.45; }

/* ── SymbolCard — bigger ticker + inline score ──────────────── */
.symbol-card-title-row {
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
}
.sym-name-xl {
  font-size: 26px; font-weight: 900; letter-spacing: -0.03em; line-height: 1; color: var(--text);
}
.sym-score-badge {
  font-size: 14px; font-weight: 800; font-family: var(--mono);
  padding: 2px 9px; border-radius: var(--r-sm); border: 1px solid;
  line-height: 1.6;
}
.symbol-card-signal-row { display: flex; gap: 5px; flex-wrap: wrap; align-items: center; margin-top: 5px; }

/* ── Trigger levels — visible without expand ────────────────── */
.symbol-card-triggers { display: flex; gap: 8px; flex-wrap: wrap; margin: 8px 0 4px; }
.sct-long, .sct-short {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 12px; border-radius: var(--r-sm); border: 1px solid;
  font-family: var(--mono); font-size: 12px;
}
.sct-long  { background: var(--green-dim); border-color: var(--green-border); }
.sct-short { background: var(--red-dim);   border-color: var(--red-border); }
.sct-label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--muted); }
.sct-long  .sct-label { color: var(--green); }
.sct-short .sct-label { color: var(--red); }
.sct-val   { font-size: 15px; font-weight: 800; }
.sct-long  .sct-val { color: var(--green); }
.sct-short .sct-val { color: var(--red); }
.sct-rr    { font-size: 10.5px; font-weight: 700; color: var(--muted); background: rgba(255,255,255,0.06); padding: 1px 6px; border-radius: 4px; }

/* ── SymbolGroupCard — prominent summary ────────────────────── */
.sym-group-headline {
  display: flex; align-items: center; justify-content: space-between; gap: 8px;
}
.sym-group-headline-left { display: flex; align-items: center; gap: 10px; }
.sym-group-appeared {
  font-size: 12px; font-weight: 600; color: var(--muted);
  background: var(--surface2); border: 1px solid var(--border2);
  padding: 2px 9px; border-radius: 12px;
}
.sym-group-top-score { font-size: 20px; font-weight: 900; font-family: var(--mono); }
.sym-group-breakdown { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.sgb-bull  { font-size: 12.5px; font-weight: 700; color: var(--green); }
.sgb-bear  { font-size: 12.5px; font-weight: 700; color: var(--red); }
.sgb-other { font-size: 12.5px; font-weight: 600; color: var(--muted); }

/* ── DecisionFilterBar — two-row layout ─────────────────────── */
.dec-filter-bar {
  display: flex; flex-direction: column; align-items: stretch; gap: 8px;
  padding: 12px 14px; background: var(--surface);
  border: 1px solid var(--border); border-radius: var(--r); margin-bottom: 12px;
}
.dec-filter-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.dec-filter-group-label {
  font-size: 10px; font-weight: 700; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap; min-width: 48px;
}
.dec-filter-btn-market.active { }

/* ── Score meter — slightly taller ──────────────────────────── */
.score-meter-track { height: 6px; }

/* ── Card spacing improvement ───────────────────────────────── */
.symbol-cards { gap: 10px; }
.symbol-card { padding: 16px 18px; }
.symbol-card-desc {
  font-size: 13px; color: var(--text); line-height: 1.5;
  margin: 8px 0 4px; border-left: 2px solid var(--border2); padding-left: 10px;
  opacity: 0.85;
}

/* ── Responsive: top-signals grid ───────────────────────────── */
@media (max-width: 900px) {
  .top-signals-grid { grid-template-columns: repeat(2, 1fr) !important; }
}
@media (max-width: 540px) {
  .top-signals-grid { grid-template-columns: 1fr !important; }
  .tsm-symbol { font-size: 22px; }
  .sym-name-xl { font-size: 22px; }
}

/* ══════════════════════════════════════════════════════════════
   MISSED BREAKOUTS v2 STYLES
   ══════════════════════════════════════════════════════════════ */

/* ── Top Summary Panel ───────────────────────────────────────── */
.mb-top-panel {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 14px 16px;
  margin-bottom: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.mb-top-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.mb-top-panel-title {
  font-size: 12px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text);
}
.mb-top-panel-count {
  font-size: 11px;
  color: var(--muted);
  font-family: var(--mono);
}
.mb-top-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.mb-top-stat {
  flex: 1 1 90px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 10px 12px;
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
}
.mb-top-stat-val {
  font-size: 22px;
  font-weight: 800;
  font-family: var(--mono);
  line-height: 1.1;
  color: var(--text);
}
.mb-top-stat-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-top-stat-hl { flex: 1 1 130px; }
.mb-top-hl-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-top-hl-sym {
  font-size: 20px;
  font-weight: 900;
  font-family: var(--mono);
  color: var(--text);
  letter-spacing: -0.02em;
  line-height: 1.1;
}
.mb-top-reason {
  display: flex;
  align-items: baseline;
  gap: 6px;
  flex-wrap: wrap;
  padding-top: 6px;
  border-top: 1px solid var(--border);
  font-size: 11.5px;
}
.mb-top-reason-label {
  color: var(--muted);
  font-size: 11px;
  white-space: nowrap;
}
.mb-top-reason-text {
  color: var(--text);
  font-style: italic;
}

/* ── MissedCard v2 ───────────────────────────────────────────── */
.mb-card-v2 { gap: 10px; }

.mb-v2-header { display: flex; flex-direction: column; gap: 6px; }
.mb-v2-sym-row { display: flex; align-items: center; gap: 8px; }
.mb-v2-sym {
  font-size: 22px;
  font-weight: 900;
  font-family: var(--mono);
  color: var(--text);
  letter-spacing: -0.02em;
  line-height: 1;
}
.mb-v2-dupe {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 10px;
  background: var(--yellow-dim);
  border: 1px solid var(--yellow-border);
  color: var(--yellow);
  letter-spacing: 0.03em;
}
.mb-v2-badges { display: flex; gap: 5px; flex-wrap: wrap; align-items: center; }
.mb-v2-time {
  font-size: 11px;
  color: var(--muted);
  font-family: var(--mono);
}

/* ── Recommendation block ────────────────────────────────────── */
.mb-v2-rec {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 9px 12px;
  border: 1px solid;
  border-radius: var(--r-sm);
}
.mb-v2-rec-key {
  font-size: 9.5px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  opacity: 0.85;
}
.mb-v2-rec-short {
  font-size: 13px;
  font-weight: 700;
}
.mb-v2-rec-desc {
  font-size: 11.5px;
  line-height: 1.45;
  opacity: 0.85;
}

/* ── Section blocks ──────────────────────────────────────────── */
.mb-v2-section { display: flex; flex-direction: column; gap: 5px; }
.mb-v2-section-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}
.mb-v2-reason-list {
  margin: 0;
  padding-left: 16px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.mb-v2-reason-list li {
  font-size: 12px;
  color: var(--text);
  line-height: 1.45;
}
.mb-v2-system-action {
  font-size: 11.5px;
  color: var(--muted);
  font-style: italic;
  padding: 4px 8px;
  background: var(--surface3);
  border-radius: var(--r-sm);
  margin-top: 2px;
}

/* ── What happened grid ──────────────────────────────────────── */
.mb-v2-happened-grid {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.mb-v2-hap-cell {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 7px 10px;
  background: var(--surface3);
  border-radius: var(--r-sm);
  border: 1px solid var(--border);
  min-width: 72px;
}
.mb-v2-hap-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-v2-hap-val { font-size: 14px; font-weight: 700; }

/* ── Continuation bar ────────────────────────────────────────── */
.mb-v2-cont-wrap { display: flex; flex-direction: column; gap: 4px; margin-top: 4px; }
.mb-v2-cont-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mb-v2-cont-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--muted);
}
.mb-v2-cont-num {
  font-size: 13px;
  font-weight: 800;
  font-family: var(--mono);
}
.mb-v2-cont-bg {
  height: 5px;
  background: var(--border2);
  border-radius: 3px;
  overflow: hidden;
}
.mb-v2-cont-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.35s ease;
}

/* ── Learn text ──────────────────────────────────────────────── */
.mb-v2-learn {
  font-size: 12px;
  color: var(--muted);
  font-style: italic;
  line-height: 1.5;
  padding: 6px 10px;
  background: var(--surface3);
  border-left: 2px solid var(--border2);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
}

/* ── Score chips ─────────────────────────────────────────────── */
.mb-v2-chips { display: flex; flex-wrap: wrap; gap: 6px; }
.mb-v2-chip {
  display: flex;
  flex-direction: column;
  gap: 1px;
  padding: 5px 9px;
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  min-width: 52px;
}
.mb-v2-chip-label {
  font-size: 9.5px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-v2-chip-val {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}

/* ── Go to date row ──────────────────────────────────────────── */
.mb-v2-goto {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  padding: 6px 10px;
  background: color-mix(in srgb, #2962FF 8%, transparent);
  border: 1px solid color-mix(in srgb, #2962FF 18%, transparent);
  border-radius: var(--r-sm);
  font-size: 12px;
}
.mb-v2-goto-label { color: var(--muted); }
.mb-v2-goto-date  { color: var(--text); font-family: var(--mono); }
.mb-v2-goto-time  { color: var(--text); font-family: var(--mono); }

@media (max-width: 600px) {
  .mb-top-grid { gap: 7px; }
  .mb-top-stat { flex: 1 1 80px; padding: 8px 10px; }
  .mb-top-stat-val { font-size: 18px; }
  .mb-v2-sym { font-size: 18px; }
  .mb-v2-happened-grid { gap: 6px; }
  .mb-v2-hap-cell { min-width: 60px; padding: 5px 8px; }
  .mb-v2-chips { gap: 4px; }
}

/* ── FilterBar two-row layout ────────────────────────────────── */
.mb-filter-bar {
  flex-direction: column;
  align-items: stretch;
  gap: 10px;
}
.mb-filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: flex-end;
}

/* ── inline rec badge (header chip) ─────────────────────────── */
.mb-v2-inline-rec {
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 2px 7px;
  border-radius: 10px;
  border: 1px solid;
  text-transform: uppercase;
}

/* ── missed description ──────────────────────────────────────── */
.mb-v2-missed-desc {
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
}

/* ── rule suggestion ─────────────────────────────────────────── */
.mb-v2-rule-suggest {
  font-size: 12px;
  color: var(--blue);
  background: rgba(59,130,246,.07);
  border: 1px solid rgba(59,130,246,.2);
  border-radius: var(--r-sm);
  padding: 6px 10px;
  line-height: 1.45;
  margin-top: 4px;
}

/* ── rec block top row ───────────────────────────────────────── */
.mb-v2-rec-top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 3px;
}

/* ══════════════════════════════════════════════════════════════
   SYSTEMETS LÄRDOM BOX
   ══════════════════════════════════════════════════════════════ */

.mb-learning-box {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  padding: 16px 18px;
  margin-bottom: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.mb-learning-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.mb-learning-icon { font-size: 22px; flex-shrink: 0; margin-top: 1px; }
.mb-learning-title {
  font-size: 14px;
  font-weight: 800;
  color: var(--text);
  letter-spacing: -0.01em;
}
.mb-learning-sub {
  font-size: 11.5px;
  color: var(--muted);
  margin-top: 1px;
}

.mb-learning-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 8px;
}
.mb-learn-item {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 10px 12px;
  background: var(--surface3);
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
}
.mb-learn-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 600;
}
.mb-learn-val {
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.35;
}
.mb-learn-val-sm { font-size: 11.5px; font-weight: 600; }

.mb-learning-recs {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.mb-learn-rec {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 12px;
  border: 1px solid;
  border-radius: var(--r-sm);
  font-size: 12px;
  flex-wrap: wrap;
}
.mb-lrec-badge {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 2px 7px;
  border: 1px solid;
  border-radius: 10px;
  white-space: nowrap;
  flex-shrink: 0;
}

.mb-learning-rule {
  display: flex;
  flex-direction: column;
  gap: 5px;
  padding: 10px 14px;
  background: var(--surface3);
  border-left: 3px solid var(--yellow);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
}
.mb-learning-rule-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--yellow);
}
.mb-learning-rule-text {
  font-size: 12.5px;
  color: var(--text);
  line-height: 1.45;
}
.mb-learning-rule-suggest {
  font-size: 12px;
  color: var(--blue);
  padding: 5px 8px;
  background: rgba(59,130,246,.07);
  border: 1px solid rgba(59,130,246,.2);
  border-radius: var(--r-sm);
  line-height: 1.45;
}

/* ══════════════════════════════════════════════════════════════
   RULE IMPACT SECTION
   ══════════════════════════════════════════════════════════════ */

.mb-rule-impact {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--r);
  margin-bottom: 16px;
  overflow: hidden;
}

.mb-rule-impact-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: none;
  border: none;
  color: var(--text);
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  text-align: left;
  transition: background 0.12s;
}
.mb-rule-impact-toggle:hover { background: var(--surface3); }
.mb-ri-toggle-icon { font-size: 11px; color: var(--muted); flex-shrink: 0; }

.mb-rule-impact-body {
  border-top: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 0;
}

.mb-ri-row {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.mb-ri-row:last-child { border-bottom: none; }

.mb-ri-top {
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
.mb-ri-rank {
  font-size: 11px;
  font-weight: 800;
  color: var(--muted);
  min-width: 22px;
  flex-shrink: 0;
}
.mb-ri-reason {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  flex: 1;
  min-width: 0;
}
.mb-ri-count {
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  font-family: var(--mono);
  flex-shrink: 0;
}

.mb-ri-stats {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.mb-ri-stat {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.mb-ri-stat-label {
  font-size: 10px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.mb-ri-stat-val {
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}

.mb-ri-suggest {
  font-size: 11.5px;
  color: var(--blue);
  background: rgba(59,130,246,.07);
  border: 1px solid rgba(59,130,246,.2);
  border-radius: var(--r-sm);
  padding: 5px 9px;
  line-height: 1.45;
}

@media (max-width: 600px) {
  .mb-learning-grid { grid-template-columns: 1fr 1fr; }
  .mb-ri-stats { gap: 10px; }
  .mb-filter-row { gap: 10px; }
}

/* ── RuleMemoryPanel ─────────────────────────────────────────────────────── */
.rm-panel {
  background: rgba(139,92,246,.08);
  border: 1px solid rgba(139,92,246,.25);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-top: 10px;
}
.rm-panel-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
}
.rm-panel-icon { font-size: 15px; }
.rm-panel-title {
  font-size: 12px;
  font-weight: 700;
  color: #a78bfa;
  flex: 1;
}
.rm-conf-badge {
  font-size: 10.5px;
  font-weight: 600;
  border: 1px solid;
  border-radius: 4px;
  padding: 2px 7px;
}
.rm-panel-msg {
  font-size: 12px;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 6px;
}
.rm-panel-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: baseline;
}
.rm-reason {
  font-size: 11px;
  color: #c4b5fd;
  font-style: italic;
}
.rm-stats {
  font-size: 11px;
  color: var(--muted);
}
.rm-boost {
  color: var(--green);
  font-weight: 700;
}

/* ── SymbolPersonalityPanel ──────────────────────────────────────────────── */
.sp-panel {
  background: rgba(52,211,153,.07);
  border: 1px solid rgba(52,211,153,.22);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-top: 10px;
}
.sp-panel-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 5px;
  flex-wrap: wrap;
}
.sp-panel-icon { font-size: 15px; }
.sp-panel-title {
  font-size: 12px;
  font-weight: 700;
  color: #6ee7b7;
  flex: 1;
}
.sp-conf-badge {
  font-size: 10.5px;
  font-weight: 600;
  border: 1px solid;
  border-radius: 4px;
  padding: 2px 7px;
}
.sp-adj-badge {
  font-size: 11px;
  font-weight: 700;
}
.sp-panel-msg {
  font-size: 12px;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 5px;
}
.sp-panel-stats {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  font-size: 11px;
  color: var(--muted);
}
.sp-sep { color: rgba(255,255,255,.2); }

/* ── RegimeProfilePanel ───────────────────────────────────────────────────── */
.rp-panel {
  background: rgba(14,165,233,.07);
  border: 1px solid rgba(14,165,233,.22);
  border-radius: var(--r-sm);
  padding: 10px 12px;
  margin-top: 10px;
}
.rp-panel-header {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 5px;
  flex-wrap: wrap;
}
.rp-panel-icon { font-size: 15px; }
.rp-panel-title {
  font-size: 12px;
  font-weight: 700;
  color: #38bdf8;
}
.rp-regime-badge {
  font-size: 10.5px;
  font-weight: 600;
  color: #7dd3fc;
  background: rgba(14,165,233,.12);
  border-radius: 4px;
  padding: 2px 7px;
  flex: 1;
}
.rp-adj-badge {
  font-size: 11px;
  font-weight: 700;
}
.rp-panel-insight {
  font-size: 12px;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 5px;
}
.rp-panel-stats {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--muted);
}
.rp-sep { color: rgba(255,255,255,.2); }

/* ── MTF Panel ────────────────────────────────────────────────────────────── */
.mtf-panel {
  background: rgba(16,185,129,.07);
  border: 1px solid rgba(16,185,129,.22);
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.mtf-panel-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.mtf-panel-icon { font-size: 13px; }
.mtf-panel-title {
  font-size: 11.5px;
  font-weight: 700;
  color: #34d399;
}
.mtf-align-badge {
  font-size: 11px;
  font-weight: 600;
  border-radius: 4px;
  padding: 2px 7px;
}
.mtf-align-confirm  { background: rgba(34,197,94,.18);  color: #4ade80; }
.mtf-align-partial  { background: rgba(250,204,21,.14);  color: #facc15; }
.mtf-align-mixed    { background: rgba(148,163,184,.12); color: #94a3b8; }
.mtf-align-conflict { background: rgba(239,68,68,.15);  color: #f87171; }
.mtf-align-neutral  { background: rgba(148,163,184,.10); color: #94a3b8; }
.mtf-adj-badge {
  font-size: 11px;
  font-weight: 700;
  border-radius: 4px;
  padding: 2px 6px;
}
.mtf-adj-pos  { background: rgba(34,197,94,.15);  color: #4ade80; }
.mtf-adj-neg  { background: rgba(239,68,68,.15);  color: #f87171; }
.mtf-adj-zero { background: rgba(148,163,184,.1); color: #94a3b8; }
.mtf-tf-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}
.mtf-tf-chip {
  font-size: 11px;
  font-weight: 600;
  border-radius: 4px;
  padding: 2px 8px;
  background: rgba(255,255,255,.06);
}
.mtf-dir-bull    { color: #4ade80; }
.mtf-dir-bear    { color: #f87171; }
.mtf-dir-neutral { color: #94a3b8; }
.mtf-detail-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}
.mtf-detail-chip {
  font-size: 10.5px;
  color: var(--muted);
  background: rgba(255,255,255,.04);
  border-radius: 4px;
  padding: 2px 7px;
}
.mtf-explanation {
  font-size: 11.5px;
  color: var(--text);
  line-height: 1.5;
  margin-top: 4px;
}

/* ── Momentum Intelligence Panel ──────────────────────────────────────────── */
.momentum-intel-panel {
  background: rgba(59,130,246,.07);
  border: 1px solid rgba(59,130,246,.22);
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.mi-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8px;
  margin: 8px 0;
}
.mi-item {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 6px;
  padding: 7px 8px;
  min-width: 0;
}
.mi-label {
  display: block;
  color: var(--muted);
  font-size: 10.5px;
  margin-bottom: 2px;
}
.mi-item strong {
  display: block;
  font-size: 12.5px;
}
.mi-score {
  display: block;
  color: var(--muted);
  font-size: 10.5px;
  margin-top: 2px;
}
.mi-watch {
  display: inline-block;
  color: var(--yellow);
  border: 1px solid var(--yellow-border);
  background: var(--yellow-dim);
  border-radius: 5px;
  padding: 2px 7px;
  font-size: 10px;
  font-weight: 800;
  margin-bottom: 6px;
}
.mi-explanations {
  display: flex;
  flex-direction: column;
  gap: 3px;
  color: var(--text);
  font-size: 11.5px;
  line-height: 1.45;
}
@media (max-width: 640px) {
  .mi-grid { grid-template-columns: 1fr; }
}

/* ── Score Calibration Panel ──────────────────────────────────────────────── */
.scal-panel {
  background: rgba(234,179,8,.07);
  border: 1px solid rgba(234,179,8,.22);
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.scal-panel-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 7px;
  flex-wrap: wrap;
}
.scal-panel-icon { font-size: 13px; }
.scal-panel-title {
  font-size: 11.5px;
  font-weight: 700;
  color: #fbbf24;
}
.scal-range-badge {
  font-size: 10.5px;
  font-weight: 600;
  background: rgba(234,179,8,.14);
  color: #fcd34d;
  border-radius: 4px;
  padding: 2px 7px;
}
.scal-adj-badge {
  font-size: 11px;
  font-weight: 700;
  border-radius: 4px;
  padding: 2px 6px;
}
.scal-adj-pos  { background: rgba(34,197,94,.15);  color: #4ade80; }
.scal-adj-neg  { background: rgba(239,68,68,.15);  color: #f87171; }
.scal-adj-zero { background: rgba(148,163,184,.1); color: #94a3b8; }
.scal-score-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  margin-bottom: 6px;
}
.scal-score-orig { color: var(--muted); }
.scal-arrow      { color: var(--muted); }
.scal-score-cal  { color: var(--text); }
.scal-stats-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--muted);
  flex-wrap: wrap;
  margin-bottom: 6px;
}
.scal-stats-row strong { color: var(--text); }
.scal-sep { color: rgba(255,255,255,.2); }
.scal-explanation {
  font-size: 11.5px;
  color: var(--text);
  line-height: 1.5;
}

/* ── PreMove Panel ─────────────────────────────────────────────────────────── */
.premove-panel { padding: 10px 12px; }
.premove-grid  { display: flex; flex-direction: column; gap: 5px; margin-bottom: 6px; }
.premove-row   { display: flex; align-items: center; gap: 6px; }
.premove-label { font-size: 11px; color: var(--muted); width: 100px; flex-shrink: 0; }
.premove-bar-wrap { flex: 1; height: 6px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.premove-bar   { height: 100%; border-radius: 3px; transition: width .3s; }
.premove-val   { font-size: 11px; font-weight: 700; width: 34px; text-align: right; flex-shrink: 0; }
.premove-meta  { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-size: 11.5px; }
.premove-bias  { font-weight: 600; }

/* ── Fatigue Panel ─────────────────────────────────────────────────────────── */
.fatigue-panel   { padding: 10px 12px; }
.fatigue-header  { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.fatigue-bar-wrap { flex: 1; height: 7px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.fatigue-bar     { height: 100%; border-radius: 3px; transition: width .3s; }
.fatigue-score   { font-size: 12px; }
.fatigue-reasons { margin: 0 0 6px 0; padding: 0 0 0 14px; font-size: 11px; color: var(--text); line-height: 1.6; }
.fatigue-reasons li { margin-bottom: 2px; }

/* ── Fakeout DNA Panel ─────────────────────────────────────────────────────── */
.dna-panel    { padding: 10px 12px; }
.dna-header   { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.dna-bar-wrap { flex: 1; height: 7px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.dna-bar      { height: 100%; border-radius: 3px; transition: width .3s; }
.dna-score    { font-size: 12px; }
.dna-features { display: flex; flex-direction: column; gap: 3px; margin-bottom: 6px; }
.dna-feature-row { display: flex; align-items: center; gap: 6px; font-size: 11px; }
.dna-feature-name { color: var(--muted); width: 110px; flex-shrink: 0; }
.dna-feature-val  { font-weight: 600; width: 80px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; }

/* ── Machine: Market Personality ───────────────────────────────────────────── */
.mc-personality-grid    { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media (max-width: 640px) { .mc-personality-grid { grid-template-columns: 1fr; } }
.mc-personality-card    { background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
.mc-personality-empty   { display: flex; align-items: center; gap: 10px; color: var(--muted); font-size: 0.85rem; }
.mc-personality-header  { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
.mc-personality-icon    { font-size: 1.6rem; line-height: 1; margin-top: 2px; }
.mc-personality-label   { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
.mc-personality-title   { font-size: 0.9rem; font-weight: 700; color: var(--text); text-transform: capitalize; }
.mc-personality-trust   { margin-left: auto; text-align: right; }
.mc-personality-sv      { font-size: 0.78rem; color: var(--text); line-height: 1.5; margin-bottom: 10px; }
.mc-personality-meters  { display: flex; flex-direction: column; gap: 4px; margin-bottom: 8px; }
.mc-pm-row              { display: flex; align-items: center; gap: 6px; }
.mc-pm-label            { font-size: 0.7rem; color: var(--muted); width: 82px; flex-shrink: 0; }
.mc-pm-bar-wrap         { flex: 1; height: 5px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.mc-pm-bar              { height: 100%; border-radius: 3px; transition: width .4s; }
.mc-pm-val              { font-size: 0.7rem; font-weight: 700; width: 24px; text-align: right; flex-shrink: 0; }
.mc-personality-meta    { font-size: 0.68rem; color: var(--muted); }

/* ── Machine: Rule Health ───────────────────────────────────────────────────── */
.mc-rule-health         { background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }

/* ── Machine: Momentum Backtest ───────────────────────────────────────────── */
.mc-mb-panel,
.mc-mb-empty {
  background: var(--card-bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
}
.mc-mb-empty {
  color: var(--muted);
  font-size: 0.85rem;
}
.mc-mb-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
  margin-bottom: 12px;
}
.mc-mb-title {
  font-weight: 800;
  color: var(--text);
  font-size: 0.95rem;
}
.mc-mb-sub {
  color: var(--muted);
  font-size: 0.78rem;
  margin-top: 3px;
}
.mc-mb-verdict {
  border-radius: 6px;
  padding: 4px 9px;
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--yellow);
  border: 1px solid var(--yellow-border);
  background: var(--yellow-dim);
  white-space: nowrap;
}
.mc-mb-hjälper { color: var(--green); border-color: var(--green-border); background: var(--green-dim); }
.mc-mb-hjälper-inte-ännu { color: var(--orange); border-color: var(--orange-border); background: var(--orange-dim); }
.mc-mb-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  margin-bottom: 10px;
}
.mc-mb-line {
  display: grid;
  grid-template-columns: 1.2fr 1.1fr auto auto;
  gap: 8px;
  align-items: center;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 6px;
  padding: 8px 10px;
  font-size: 0.76rem;
  min-width: 0;
}
.mc-mb-line span { color: var(--muted); }
.mc-mb-line strong {
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mc-mb-sweep {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  color: var(--muted);
  border-top: 1px solid var(--border);
  padding-top: 10px;
  font-size: 0.8rem;
}
.mc-mb-sweep strong { color: var(--text); }
.mc-mb-conclusion {
  margin-top: 10px;
  color: var(--text);
  font-size: 0.82rem;
  line-height: 1.5;
}
@media (max-width: 820px) {
  .mc-mb-grid { grid-template-columns: 1fr; }
  .mc-mb-line { grid-template-columns: 1fr; }
  .mc-mb-top,
  .mc-mb-sweep { flex-direction: column; }
}

/* ── System Health ────────────────────────────────────────────────────────── */
.sh-hero {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 18px 20px;
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  margin-bottom: 18px;
  background: var(--surface);
}
.sh-healthy { border-color: var(--green-border); background: var(--green-dim); }
.sh-warning { border-color: var(--yellow-border); background: var(--yellow-dim); }
.sh-critical { border-color: var(--red); background: var(--red-dim); }
.sh-hero-title {
  font-size: 1.35rem;
  font-weight: 850;
  color: var(--text);
}
.sh-hero-sub {
  color: var(--muted);
  font-size: 0.9rem;
  margin-top: 4px;
}
.sh-hero-status {
  font-family: var(--mono);
  font-weight: 800;
  font-size: 0.9rem;
  color: var(--text);
}
.sh-alert-banner {
  border: 1px solid var(--red);
  background: var(--red-dim);
  color: var(--text);
  border-radius: 8px;
  padding: 12px 14px;
  margin-bottom: 16px;
}
.sh-alert-line {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-top: 8px;
  font-size: 0.82rem;
}
.sh-alert-line em {
  color: var(--muted);
  font-style: normal;
}
.sh-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 12px;
}
.sh-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 13px 14px;
}
.sh-card-head {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}
.sh-card-title {
  font-weight: 800;
  color: var(--text);
  font-size: 0.95rem;
}
.sh-card-message {
  color: var(--muted);
  font-size: 0.78rem;
  line-height: 1.45;
  margin-top: 4px;
}
.sh-status,
.sh-mini-status {
  border-radius: 5px;
  padding: 2px 7px;
  font-size: 0.68rem;
  font-weight: 850;
  white-space: nowrap;
}
.sh-on { color: var(--green); border-color: var(--green-border); background: var(--green-dim); }
.sh-stale { color: var(--yellow); border-color: var(--yellow-border); background: var(--yellow-dim); }
.sh-broken { color: var(--red); border-color: var(--red); background: var(--red-dim); }
.sh-status.sh-on,
.sh-mini-status.sh-on { border: 1px solid var(--green-border); }
.sh-status.sh-stale,
.sh-mini-status.sh-stale { border: 1px solid var(--yellow-border); }
.sh-status.sh-broken,
.sh-mini-status.sh-broken { border: 1px solid var(--red); }
.sh-card-foot {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
  color: var(--muted);
  font-size: 0.74rem;
  margin-top: 12px;
}
.sh-detail-btn {
  font-size: 0.72rem;
  padding: 3px 8px;
}
.sh-details {
  border-top: 1px solid var(--border);
  margin-top: 10px;
  padding-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.sh-component {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 8px;
  align-items: center;
  font-size: 0.75rem;
}
.sh-dot {
  width: 8px;
  height: 8px;
  border-radius: 99px;
  display: inline-block;
}
.sh-component-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.sh-component-name {
  color: var(--text);
  font-weight: 700;
}
.sh-component-msg {
  color: var(--muted);
  line-height: 1.35;
}
.sh-component-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--muted);
}
@media (max-width: 640px) {
  .sh-hero,
  .sh-card-foot,
  .sh-component,
  .sh-component-meta {
    align-items: flex-start;
    grid-template-columns: 1fr;
    flex-direction: column;
  }
}

/* ── Alerts Page ──────────────────────────────────────────────────────────── */
.al-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 10px;
}
.al-list {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 10px;
}
.al-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 13px 14px;
}
.al-card.al-critical { border-color: var(--red); background: var(--red-dim); }
.al-card.al-high { border-color: var(--orange-border); background: var(--orange-dim); }
.al-card.al-watch { border-color: var(--yellow-border); background: var(--yellow-dim); }
.al-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 8px;
}
.al-title {
  color: var(--text);
  font-size: 0.92rem;
  font-weight: 800;
}
.al-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  color: var(--muted);
  font-size: 0.7rem;
  margin-top: 3px;
}
.al-severity {
  border-radius: 5px;
  padding: 2px 7px;
  font-size: 0.68rem;
  font-weight: 850;
  border: 1px solid var(--border);
}
.al-severity.al-critical { color: var(--red); border-color: var(--red); }
.al-severity.al-high { color: var(--orange); border-color: var(--orange-border); }
.al-severity.al-watch { color: var(--yellow); border-color: var(--yellow-border); }
.al-severity.al-info { color: var(--blue); border-color: var(--blue-border); }
.al-message {
  color: var(--text);
  font-size: 0.8rem;
  line-height: 1.45;
}
.al-action {
  color: var(--muted);
  font-size: 0.76rem;
  line-height: 1.4;
  margin-top: 7px;
}
.al-card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 10px;
}
.al-ack-btn {
  font-size: 0.72rem;
  padding: 3px 9px;
}

.ux-technical {
  margin-top: 8px;
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
}
.ux-technical summary {
  cursor: pointer;
  color: var(--text);
  font-weight: 600;
}
.ux-tech-box {
  margin-top: 10px;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: var(--r-sm);
  background: rgba(255,255,255,.03);
  color: var(--muted);
  font-size: 12px;
  overflow-wrap: anywhere;
}
.ux-help-text {
  margin-top: 6px;
  color: var(--muted);
  font-size: 12px;
}
.ux-feed-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
}
.ux-feed-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 14px;
}
.ux-feed-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 10px;
}
.ux-feed-line {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.6;
}

@media (max-width: 640px) {
  .al-card-actions {
    flex-direction: column;
    gap: 8px;
  }
  .al-card-actions .btn {
    width: 100%;
  }
  .hero-empty {
    align-items: flex-start;
  }
  .ux-feed-top {
    align-items: flex-start;
  }
}
.mc-rule-health-empty   { color: var(--muted); font-size: 0.82rem; padding: 12px; }
.mc-rh-stats            { display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
.mc-rh-stat             { display: flex; flex-direction: column; align-items: center; }
.mc-rh-stat-val         { font-size: 1.1rem; font-weight: 700; }
.mc-rh-stat-label       { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; }
.mc-rh-section          { margin-bottom: 10px; }
.mc-rh-section-title    { font-size: 0.72rem; font-weight: 700; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .04em; }
.mc-rh-rule             { display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 0.78rem; border-bottom: 1px solid rgba(255,255,255,.05); }
.mc-rh-rule-label       { flex: 1; color: var(--text); font-weight: 500; }
.mc-rh-rule-rates       { display: flex; align-items: center; gap: 4px; font-size: 0.75rem; }
.mc-rh-rule-arrow       { color: var(--muted); }
.mc-rh-rule-drift       { font-weight: 700; font-size: 0.75rem; width: 36px; text-align: right; }
.mc-rh-all-stable       { color: var(--green); font-size: 0.82rem; padding: 8px 0; }

/* ── StateGraphPanel ────────────────────────────────────────────────────────── */
.sg-panel               { background: rgba(129,140,248,.07); border: 1px solid rgba(129,140,248,.18); border-radius: 10px; padding: 12px 14px; margin-bottom: 10px; }
.sg-header              { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
.sg-title               { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); flex-shrink: 0; }
.sg-state-badge         { font-size: 0.72rem; font-weight: 700; color: #fff; padding: 2px 8px; border-radius: 99px; }
.sg-cycle-badge         { font-size: 0.68rem; font-weight: 600; margin-left: auto; }
.sg-conf-row            { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.sg-conf-label          { font-size: 0.65rem; color: var(--muted); width: 58px; flex-shrink: 0; }
.sg-bar-wrap            { flex: 1; height: 5px; background: rgba(255,255,255,.08); border-radius: 3px; overflow: hidden; }
.sg-bar                 { height: 100%; border-radius: 3px; transition: width .5s; }
.sg-conf-val            { font-size: 0.7rem; font-weight: 700; width: 30px; text-align: right; }
.sg-insight             { font-size: 0.76rem; color: var(--text); margin-bottom: 10px; padding: 6px 8px; background: rgba(255,255,255,.04); border-radius: 6px; font-style: italic; }
.sg-transitions         { margin-bottom: 8px; }
.sg-trans-label         { font-size: 0.65rem; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; margin-bottom: 5px; }
.sg-trans-row           { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.sg-trans-state         { font-size: 0.7rem; font-weight: 600; width: 80px; flex-shrink: 0; }
.sg-trans-bar-wrap      { flex: 1; height: 4px; background: rgba(255,255,255,.06); border-radius: 3px; overflow: hidden; }
.sg-trans-bar           { height: 100%; border-radius: 3px; opacity: .7; transition: width .4s; }
.sg-trans-pct           { font-size: 0.65rem; color: var(--muted); width: 28px; text-align: right; }
.sg-meta                { display: flex; gap: 6px; flex-wrap: wrap; }
.sg-meta-chip           { font-size: 0.65rem; color: var(--muted); background: rgba(255,255,255,.05); padding: 2px 7px; border-radius: 99px; }

/* ── Machine: State Graph Distribution ─────────────────────────────────────── */
.sg-dist-grid           { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .sg-dist-grid { grid-template-columns: 1fr; } }
.sg-dist-panel          { background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; }
.sg-dist-title          { font-size: 0.8rem; font-weight: 700; margin-bottom: 10px; }
.sg-dist-total          { font-weight: 400; color: var(--muted); }
.sg-dist-empty          { color: var(--muted); font-size: 0.82rem; }
.sg-dist-row            { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
.sg-dist-label          { font-size: 0.7rem; font-weight: 600; width: 84px; flex-shrink: 0; }
.sg-dist-bar-wrap       { flex: 1; height: 5px; background: rgba(255,255,255,.07); border-radius: 3px; overflow: hidden; }
.sg-dist-bar            { height: 100%; border-radius: 3px; opacity: .75; transition: width .5s; }
.sg-dist-count          { font-size: 0.68rem; font-weight: 700; color: var(--muted); width: 16px; text-align: right; }

/* ── OrchestratorPanel ──────────────────────────────────────────────────────── */
.orch-panel             { background: rgba(99,102,241,.07); border: 1px solid rgba(99,102,241,.18); border-radius: 10px; padding: 10px 14px; margin-bottom: 10px; }
.orch-header            { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; flex-wrap: wrap; }
.orch-title             { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }
.orch-conflict-badge    { font-size: 0.66rem; font-weight: 700; color: #fbbf24; background: rgba(251,191,36,.12); padding: 1px 6px; border-radius: 99px; }
.orch-final             { font-size: 0.78rem; font-weight: 700; margin-left: auto; }
.orch-rows              { display: flex; flex-direction: column; gap: 3px; margin-bottom: 6px; }
.orch-row               { display: flex; align-items: center; justify-content: space-between; font-size: 0.73rem; }
.orch-engine            { color: var(--text-muted); }
.orch-adj               { font-weight: 700; font-size: 0.73rem; }
.orch-note              { font-size: 0.68rem; color: #fbbf24; font-style: italic; }

/* ── DecayPanel ─────────────────────────────────────────────────────────────── */
.decay-panel        { background: rgba(251,191,36,.07); border: 1px solid rgba(251,191,36,.22); border-radius: 10px; padding: 9px 14px; margin-bottom: 10px; }
.decay-header       { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
.decay-title        { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: #fbbf24; }
.decay-badge        { font-size: 0.7rem; font-weight: 600; color: #fbbf24; background: rgba(251,191,36,.12); padding: 1px 7px; border-radius: 99px; }
.decay-penalty      { font-size: 0.78rem; font-weight: 700; color: var(--red); margin-left: auto; }
.decay-explanation  { font-size: 0.72rem; color: var(--text-muted); font-style: italic; }

/* ── Live Intelligence Panel ────────────────────────────────────────────────── */
.li-panel               { background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
.li-section             { }
.li-section-title       { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); margin-bottom: 8px; }
.li-row                 { display: flex; align-items: center; gap: 6px; padding: 3px 0; font-size: 0.76rem; border-bottom: 1px solid rgba(255,255,255,.04); }
.li-sym                 { font-weight: 700; width: 52px; flex-shrink: 0; }
.li-state               { flex: 1; font-size: 0.7rem; }
.li-score               { font-weight: 700; font-size: 0.73rem; flex-shrink: 0; }

/* ── Simplified Navigation ──────────────────────────────────────────────────── */
.nav-live:hover         { color: var(--green); }
.nav-live.active        { color: var(--green); border-bottom-color: var(--green); }
.nav-intel:hover        { color: #818cf8; }
.nav-intel.active       { color: #818cf8; border-bottom-color: #818cf8; }
.nav-health-lnk:hover   { color: #22d3ee; }
.nav-health-lnk.active  { color: #22d3ee; border-bottom-color: #22d3ee; }
.nav-alerts-link:hover  { color: #fbbf24; }
.nav-alerts-link.active { color: #fbbf24; border-bottom-color: #fbbf24; }
.nav-alerts-link        { position: relative; }

/* Active alert badges on nav */
.nav-badge              { position: absolute; top: 10px; right: 8px; width: 7px; height: 7px; border-radius: 50%; background: #ef4444; }
.nav-live-dot           { position: absolute; top: 10px; right: 2px; width: 5px; height: 5px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }

/* Advanced dropdown button */
.nav-adv-wrap           { position: relative; display: flex; align-items: stretch; }
.nav-adv-btn            { cursor: pointer; border: none; background: none; gap: 4px; }
.nav-adv-btn:hover      { color: var(--text); }
.nav-adv-btn.active     { color: var(--text); border-bottom-color: var(--border); }
.nav-adv-chevron        { font-size: 0.55rem; opacity: .6; }

/* Dropdown panel */
.nav-adv-dropdown       { position: absolute; top: calc(100% + 2px); right: 0; z-index: 200;
                          background: var(--surface); border: 1px solid var(--border);
                          border-radius: 10px; padding: 6px; min-width: 180px;
                          box-shadow: 0 8px 32px rgba(0,0,0,.4); }
.nav-adv-item           { display: flex; align-items: center; gap: 10px; padding: 8px 12px;
                          border-radius: 6px; color: var(--muted); text-decoration: none;
                          font-size: 13px; font-weight: 500; transition: background .12s, color .12s; }
.nav-adv-item:hover     { background: rgba(255,255,255,.06); color: var(--text); }
.nav-adv-item.active    { color: var(--blue); background: rgba(59,130,246,.1); }
.nav-adv-icon           { font-size: 0.95rem; width: 20px; text-align: center; }

/* ── LivePage ────────────────────────────────────────────────────────────────── */
.live-pulse-strip       { display: flex; gap: 2px; margin: 0 0 12px; flex-wrap: wrap; }
.live-pulse-item        { display: flex; align-items: center; gap: 8px; background: var(--card-bg);
                          border: 1px solid var(--border); border-radius: 8px; padding: 6px 14px; flex: 1; min-width: 160px; }
.live-pulse-label       { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); }
.live-pulse-val         { font-size: 0.8rem; font-weight: 600; color: var(--text); flex: 1; }
.live-pulse-trust       { font-size: 0.68rem; color: var(--muted); }

.live-warnings          { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.live-warning-row       { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px;
                          background: rgba(255,255,255,.03); border-left: 3px solid #f97316;
                          border-radius: 0 8px 8px 0; font-size: 0.8rem; color: var(--text); }

/* Watch mode grid */
.live-watch-grid        { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
.live-watch-card        { background: rgba(129,140,248,.06); border: 1px solid rgba(129,140,248,.15);
                          border-radius: 10px; padding: 12px 14px; }
.live-watch-top         { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
.live-watch-sym         { font-size: 0.9rem; font-weight: 800; color: var(--text); }
.live-watch-meta        { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 8px; }
.live-watch-chip        { font-size: 0.65rem; font-weight: 600; padding: 2px 7px; border-radius: 99px; }
.live-chip-premove      { background: rgba(129,140,248,.18); color: #818cf8; }
.live-chip-rule         { background: rgba(16,185,129,.12); color: #10b981; }
.live-chip-conf         { background: rgba(251,191,36,.12); color: #fbbf24; }
.live-watch-bar-wrap    { position: relative; height: 4px; background: rgba(255,255,255,.07); border-radius: 3px; overflow: hidden; }
.live-watch-bar         { height: 100%; background: #818cf8; border-radius: 3px; opacity: .7; }
.live-watch-bar-label   { position: absolute; top: 6px; left: 0; font-size: 0.6rem; color: var(--muted); }

/* ── AlertsPage feed ────────────────────────────────────────────────────────── */
.alert-toggle-card      { background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; padding: 18px 20px; }
.alert-toggle-status    { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 14px; }
.alert-toggle-dot       { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; margin-top: 3px; }
.dot-on                 { background: var(--green); box-shadow: 0 0 8px var(--green); }
.dot-off                { background: var(--muted); }
.alert-toggle-label     { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.alert-toggle-sub       { font-size: 0.78rem; color: var(--muted); }
.alert-toggle-actions   { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.btn-alert-on           { background: rgba(34,197,94,.15); color: var(--green); border-color: rgba(34,197,94,.3); }
.btn-alert-off          { background: rgba(239,68,68,.1); color: var(--red); border-color: rgba(239,68,68,.25); }
.btn-alert-warn         { background: rgba(251,191,36,.1); color: #fbbf24; border-color: rgba(251,191,36,.25); }
.alert-notif-status     { font-size: 0.72rem; color: var(--muted); }
.alert-feed             { display: flex; flex-direction: column; gap: 4px; }
.alert-feed-row         { display: flex; align-items: center; gap: 10px; padding: 10px 14px;
                          background: var(--card-bg); border: 1px solid var(--border);
                          border-radius: 8px; text-decoration: none; color: var(--text);
                          transition: background .12s; }
.alert-feed-row:hover   { background: rgba(255,255,255,.05); }
.alert-feed-stale       { opacity: .75; }
.alert-feed-sym         { font-size: 0.88rem; font-weight: 800; width: 64px; flex-shrink: 0; }
.alert-feed-meta        { flex: 1; display: flex; flex-wrap: wrap; gap: 5px; }
.alert-feed-regime      { font-size: 0.65rem; background: rgba(255,255,255,.06); padding: 1px 6px; border-radius: 4px; color: var(--muted); }
.alert-feed-state       { font-size: 0.65rem; background: rgba(129,140,248,.12); color: #818cf8; padding: 1px 6px; border-radius: 4px; }
.alert-feed-event       { font-size: 0.65rem; background: rgba(16,185,129,.1); color: #10b981; padding: 1px 6px; border-radius: 4px; }

@media (max-width: 500px) {
  .nav-adv-dropdown     { right: -60px; }
  .live-watch-grid      { grid-template-columns: 1fr 1fr; }
}

.page-loading { padding: 40px; text-align: center; color: var(--muted); }


.app-logo {
  width: 36px;
  height: 36px;
  object-fit: contain;
  border-radius: 10px;
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .app-logo {
    width: 30px;
    height: 30px;
    border-radius: 8px;
  }
}

/* ── AI Copilot ─────────────────────────────────────────────────────────────── */
.ai-fab {
  position: fixed;
  right: 18px;
  bottom: 18px;
  z-index: 260;
  border: 1px solid rgba(34,197,94,.35);
  background: rgba(10, 16, 28, .96);
  color: var(--text);
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 0.82rem;
  font-weight: 850;
  box-shadow: 0 10px 34px rgba(0,0,0,.35);
  cursor: pointer;
}
.ai-fab:hover { border-color: var(--green); color: var(--green); }
.ai-shell {
  position: fixed;
  inset: 0;
  z-index: 500;
  pointer-events: none;
}
.ai-backdrop {
  position: absolute;
  inset: 0;
  border: 0;
  background: rgba(0,0,0,.45);
  pointer-events: auto;
}
.ai-panel {
  position: absolute;
  top: 0;
  right: 0;
  width: min(430px, 100vw);
  height: 100%;
  background: var(--surface);
  border-left: 1px solid var(--border);
  box-shadow: -18px 0 60px rgba(0,0,0,.42);
  padding: 18px;
  overflow-y: auto;
  pointer-events: auto;
}
.ai-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 10px;
}
.ai-kicker {
  color: var(--green);
  font-size: 0.68rem;
  font-weight: 850;
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.ai-head h2 {
  margin: 0;
  font-size: 1.25rem;
  letter-spacing: -0.02em;
}
.ai-close {
  border: 1px solid var(--border);
  background: rgba(255,255,255,.03);
  color: var(--text);
  border-radius: 8px;
  width: 34px;
  height: 34px;
  font-size: 1.25rem;
  cursor: pointer;
}
.ai-intro,
.ai-risk {
  color: var(--muted);
  font-size: 0.78rem;
  line-height: 1.45;
}
.ai-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin: 14px 0;
}
.ai-examples button {
  border: 1px solid var(--border);
  background: rgba(255,255,255,.04);
  color: var(--text);
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 0.75rem;
  cursor: pointer;
}
.ai-examples button:hover { border-color: rgba(34,197,94,.45); }
.ai-label {
  display: block;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 800;
  margin: 12px 0 6px;
}
.ai-panel textarea {
  width: 100%;
  resize: vertical;
  min-height: 108px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(0,0,0,.18);
  color: var(--text);
  padding: 10px 11px;
  font: inherit;
  line-height: 1.45;
}
.ai-submit {
  width: 100%;
  margin-top: 10px;
  border: 1px solid rgba(34,197,94,.38);
  background: rgba(34,197,94,.12);
  color: var(--green);
  border-radius: 10px;
  padding: 10px 12px;
  font-weight: 850;
  cursor: pointer;
}
.ai-submit:disabled,
.ai-examples button:disabled {
  opacity: .55;
  cursor: not-allowed;
}
.ai-error,
.ai-answer {
  margin-top: 14px;
  border-radius: 10px;
  padding: 12px;
  line-height: 1.5;
  white-space: pre-wrap;
}
.ai-error {
  border: 1px solid var(--yellow-border);
  background: var(--yellow-dim);
  color: var(--yellow);
  font-size: 0.8rem;
}
.ai-answer {
  border: 1px solid var(--border);
  background: rgba(255,255,255,.035);
  color: var(--text);
  font-size: 0.84rem;
}
.ai-risk {
  margin-top: 12px;
  border-top: 1px solid var(--border);
  padding-top: 12px;
}

@media (max-width: 640px) {
  .ai-fab { right: 12px; bottom: 12px; padding: 9px 12px; }
  .ai-panel { width: 100vw; padding: 16px; }
}

/* ── Live clarity pass ─────────────────────────────────────────────────────── */
.live-hero {
  border-color: rgba(125, 211, 252, .38);
  background:
    radial-gradient(circle at 18% 0%, rgba(34,197,94,.13), transparent 34%),
    radial-gradient(circle at 82% 10%, rgba(59,130,246,.14), transparent 34%),
    linear-gradient(135deg, #0b111d 0%, #101827 58%, #0b1019 100%);
  box-shadow: 0 18px 58px rgba(0,0,0,.32), inset 0 1px 0 rgba(255,255,255,.09);
}
.live-hero-bg { opacity: .12; }
.live-hero h1 {
  color: #f8fbff;
  letter-spacing: 0;
  text-shadow: 0 1px 18px rgba(125,211,252,.16);
}
.live-hero p,
.live-section-sub {
  color: #b9c4d8;
}
.live-kicker {
  color: #7dd3fc;
}
.live-refresh-btn {
  border-color: rgba(74,222,128,.62);
  background: rgba(34,197,94,.18);
  color: #bbf7d0;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
}
.live-refresh-btn:hover {
  background: rgba(34,197,94,.26);
  border-color: #4ade80;
  color: #ecfdf5;
}
.live-stat,
.live-command-section,
.live-best-card,
.pulse-card,
.live-pulse-item,
.live-watch-card,
.live-advanced-wrap {
  border-color: rgba(148,163,184,.26);
}
.live-stat {
  background: rgba(10,16,28,.9);
}
.live-stat span,
.live-best-grid span,
.live-pulse-label,
.live-pulse-trust {
  color: #a8b3c8;
}
.live-stat strong {
  color: #f8fafc;
  font-size: 17px;
}
.live-stat small {
  display: block;
  color: #a8b3c8;
  font-size: 11px;
  line-height: 1.35;
  margin-top: 6px;
  text-transform: none;
  letter-spacing: 0;
}
.live-stat strong.strong { color: #4ade80; }
.live-stat strong.watch { color: #facc15; }
.live-stat strong.risk { color: #fb7185; }
.live-system-note {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: 12px;
  border: 1px solid rgba(250,204,21,.34);
  border-left-width: 4px;
  border-radius: 10px;
  background: rgba(250,204,21,.12);
  padding: 12px 14px;
}
.live-system-note.risk {
  border-color: rgba(248,113,113,.42);
  background: rgba(239,68,68,.13);
}
.live-system-note strong {
  color: #fef9c3;
  font-size: 13px;
}
.live-system-note.risk strong {
  color: #fecaca;
}
.live-system-note span {
  color: #f8fafc;
  font-size: 13px;
  line-height: 1.45;
}
.live-command-section {
  background: linear-gradient(180deg, rgba(17,24,39,.98), rgba(12,18,30,.98));
}
.live-section-title {
  color: #f8fafc;
  font-size: 16px;
}
.live-calm-state {
  display: flex;
  flex-direction: column;
  gap: 5px;
  border-color: rgba(74,222,128,.38);
  background: rgba(34,197,94,.08);
  color: #cbd5e1;
}
.live-calm-state strong {
  color: #bbf7d0;
  font-size: 15px;
}
.pulse-card {
  background: #0d1524;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
}
.pulse-card:hover {
  border-color: rgba(125,211,252,.45);
  transform: translateY(-1px);
}
.pulse-symbol,
.live-simple-symbol,
.live-best-symbol {
  color: #f8fafc;
  letter-spacing: 0;
}
.pulse-status,
.live-simple-status {
  border: 1px solid currentColor;
  border-radius: 999px;
  padding: 3px 8px;
  background: rgba(255,255,255,.05);
}
.pulse-card-bottom,
.pulse-why,
.live-simple-reason,
.live-simple-rank {
  color: #b9c4d8;
}
.live-best-grid div {
  border-color: rgba(148,163,184,.22);
  background: rgba(15,23,42,.88);
}
.live-best-grid strong {
  color: #eef2ff;
}
.live-best-dir {
  color: #cbd5e1;
}
.live-best-action {
  border-color: rgba(250,204,21,.48);
  background: rgba(250,204,21,.14);
  color: #fef08a;
}
.live-best-strong .live-best-action {
  border-color: rgba(74,222,128,.52);
  background: rgba(34,197,94,.18);
  color: #bbf7d0;
}
.live-best-confirmation {
  display: flex;
  flex-direction: column;
  gap: 3px;
  margin: -2px 0 14px;
  border: 1px solid rgba(250,204,21,.36);
  border-radius: 10px;
  background: rgba(250,204,21,.1);
  padding: 11px 12px;
}
.live-best-confirmation strong {
  color: #fef08a;
  font-size: 13px;
}
.live-best-confirmation span {
  color: #f8fafc;
  font-size: 12px;
  line-height: 1.45;
}
.btn.btn-tv {
  border-color: rgba(96,165,250,.75);
  background: rgba(59,130,246,.18);
  color: #bfdbfe;
  font-weight: 850;
  padding: 7px 12px;
}
.btn.btn-tv:hover {
  background: rgba(59,130,246,.28);
  border-color: #93c5fd;
  color: #eff6ff;
}
.btn-secondary,
.live-advanced-toggle {
  border-color: rgba(148,163,184,.32);
  background: rgba(148,163,184,.08);
  color: #cbd5e1;
}
.btn-secondary:hover,
.live-advanced-toggle:hover {
  border-color: rgba(203,213,225,.5);
  background: rgba(148,163,184,.14);
  color: #f8fafc;
}
.live-simple-list {
  gap: 8px;
}
.live-simple-row {
  grid-template-columns: 42px minmax(86px, 1fr) 112px 92px minmax(160px, 2fr);
  gap: 12px;
  border: 1px solid rgba(148,163,184,.2);
  border-radius: 10px;
  background: rgba(15,23,42,.72);
  padding: 12px;
}
.live-simple-row:last-child {
  border-bottom: 1px solid rgba(148,163,184,.2);
}
.live-simple-score {
  color: #f8fafc;
  font-family: var(--mono);
  font-weight: 900;
  text-align: right;
}
.live-simple-status.strong { color: #4ade80; }
.live-simple-status.watch { color: #facc15; }
.live-simple-status.risk { color: #fb7185; }
.live-simple-status.wait { color: #93c5fd; }
.live-warning-row {
  border: 1px solid rgba(249,115,22,.28);
  border-left-width: 4px;
  background: rgba(249,115,22,.1);
  color: #f8fafc;
}
.live-pulse-item {
  background: rgba(15,23,42,.9);
}
.live-pulse-val {
  color: #eef2ff;
}

@media (max-width: 760px) {
  .live-simple-row {
    grid-template-columns: 34px 1fr auto;
    align-items: flex-start;
  }
  .live-simple-score {
    grid-column: 2 / -1;
    text-align: left;
  }
  .live-simple-reason {
    grid-column: 2 / -1;
    white-space: normal;
  }
  .live-stat small {
    font-size: 10.5px;
  }
}

@media (max-width: 480px) {
  .live-hero h1 {
    font-size: 2rem;
    line-height: 1.05;
  }
  .live-simple-row {
    grid-template-columns: 30px 1fr;
  }
  .live-simple-status,
  .live-simple-score,
  .live-simple-reason {
    grid-column: 2 / -1;
  }
}
