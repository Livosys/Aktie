import React, { useState, useEffect, useCallback, useMemo } from 'react';
import {
  SectionHeader, DecisionHeroCard, tvLink, cryptoTvLink, TradeScoreBadge,
} from '../shared.jsx';
import { useAlerts } from '../alertContext.jsx';
import { enrichWithDecisions, getBestSignal, getTopN, isAvoidSignal } from '../decisionEngine.js';
import { isCryptoSymbol, openTradingView } from '../utils/tradingView.js';

const REFRESH_MS = 15_000;

function tvLinkFor(r) {
  return isCryptoSymbol(r?.symbol) ? cryptoTvLink(r.symbol) : tvLink(r.symbol);
}

function scoreOf(r) {
  return r?.priorityScore ?? r?._decision?.signalScore ?? r?.tradeScore ?? 0;
}

function directionSv(r) {
  if (r?.signal?.startsWith('LONG')) return 'Uppåt';
  if (r?.signal?.startsWith('SHORT')) return 'Nedåt';
  if (r?.momentumBias === 'bullish') return 'Uppåt';
  if (r?.momentumBias === 'bearish') return 'Nedåt';
  return 'Avvakta';
}

function simpleStatus(r) {
  if (r?.autoFilter?.blocked || r?.fakeoutRiskLevel === 'high' || (r?.fakeoutProbability ?? 0) >= 70) return 'RISK';
  const score = scoreOf(r);
  if (score >= 70) return 'STARK';
  if (r?.watchMode || r?.momentumWatchMode || r?.liquiditySweepWatchMode || score >= 45) return 'BEVAKA';
  return 'VÄNTA';
}

function statusClass(status) {
  if (status === 'STARK') return 'strong';
  if (status === 'RISK') return 'risk';
  if (status === 'BEVAKA') return 'watch';
  return 'wait';
}

function whyNow(r) {
  return r?.whyNowSv ||
    r?._decision?.explanation ||
    r?.actionSv ||
    r?.momentumExplanationSv ||
    r?.scoreExplanationSv?.[0] ||
    'Systemet bevakar läget och väntar på tydligare bekräftelse.';
}

function riskSv(r) {
  if (r?.fakeoutRiskLevel === 'high' || (r?.fakeoutProbability ?? 0) >= 70) return 'Hög risk för falsk rörelse.';
  if (r?.liquiditySweepDetected) return 'Stopjakt kan vara intressant, men historiken visar ännu inte att den ger bättre resultat.';
  if (r?.autoFilter?.blocked) return 'Reglerna blockerar läget. Jaga inte.';
  return 'Ingen tydlig varningsflagga just nu.';
}

// ── Multi-source scan hook ────────────────────────────────────────────────────

function useMultiScan() {
  const [stocks, setStocks] = useState([]);
  const [crypto, setCrypto] = useState([]);
  const [nasdaq, setNasdaq] = useState([]);
  const [loading, setLoading] = useState(true);
  const [lastFetch, setLastFetch] = useState(null);

  const fetchAll = useCallback(async () => {
    try {
      const [s, c, n] = await Promise.all([
        fetch('/api/scan/stocks').then(r => r.ok ? r.json() : null).catch(() => null),
        fetch('/api/scan/crypto').then(r => r.ok ? r.json() : null).catch(() => null),
        fetch('/api/scan/nasdaq').then(r => r.ok ? r.json() : null).catch(() => null),
      ]);
      setStocks(s?.results || []);
      setCrypto(c?.results || []);
      setNasdaq(n?.results || []);
      setLastFetch(new Date());
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchAll();
    const t = setInterval(fetchAll, REFRESH_MS);
    return () => clearInterval(t);
  }, [fetchAll]);

  return { stocks, crypto, nasdaq, loading, lastFetch, refresh: fetchAll };
}

// ── Personality hook (for risk warnings) ─────────────────────────────────────

function usePersonality() {
  const [data, setData] = useState(null);
  useEffect(() => {
    fetch('/api/market/personality')
      .then(r => r.ok ? r.json() : null)
      .then(d => { if (d) setData(d); })
      .catch(() => {});
  }, []);
  return data;
}

// ── Risk warning banner ───────────────────────────────────────────────────────

const REGIME_SV = {
  BULLISH_TREND: 'Bullish trend', BEARISH_TREND: 'Bearish trend',
  CHOPPY: 'Choppig', RANGE_DAY: 'Rangedag', TREND_DAY_UP: 'Trend upp',
  TREND_DAY_DOWN: 'Trend ned', HIGH_VOLATILITY: 'Hög volatilitet',
  PANIC: 'Panik', UNKNOWN: 'Okänt',
};

function RiskWarnings({ personality, allResults }) {
  const warnings = [];

  const stocks = personality?.stocks;
  const crypto = personality?.crypto;

  if (stocks?.fakeoutRisk > 55)
    warnings.push({ icon: '⚠️', text: `Hög risk för falska rörelser i aktier (${stocks.fakeoutRisk}%). Gå långsammare fram.`, color: '#f97316' });
  if (stocks?.exhaustionLevel > 65)
    warnings.push({ icon: '⚠', text: `Aktier ser trötta ut (${stocks.exhaustionLevel}%). Vänta på bättre läge.`, color: '#ef4444' });
  if (crypto?.fakeoutRisk > 60)
    warnings.push({ icon: '⚠️', text: `Hög risk för falska rörelser i krypto (${crypto.fakeoutRisk}%).`, color: '#f97316' });

  const staleCount = allResults.filter(r => r?.decayContext?.stale).length;
  if (staleCount >= 3)
    warnings.push({ icon: '⏳', text: `${staleCount} signaler åldras utan start. Marknaden är stökig.`, color: '#fbbf24' });

  if (warnings.length === 0) return null;

  return (
    <div className="live-warnings">
      {warnings.map((w, i) => (
        <div key={i} className="live-warning-row" style={{ borderLeftColor: w.color }}>
          <span>{w.icon}</span>
          <span>{w.text}</span>
        </div>
      ))}
    </div>
  );
}

// ── Watch mode panel ──────────────────────────────────────────────────────────

function WatchModePanel({ allResults }) {
  const watching = allResults.filter(r =>
    r.price &&
    !isAvoidSignal(r) &&
    (r.preMoveContext?.preMoveWatchMode === true ||
     r.ruleMemory?.watchMode === true ||
     r.confidence?.label === 'Bevaka')
  ).sort((a, b) => (b.tradeScore ?? 0) - (a.tradeScore ?? 0)).slice(0, 6);

  if (watching.length === 0) return null;

  return (
    <div className="sec">
      <SectionHeader
        icon="👁"
        title="Bevakningsläge"
        count={watching.length}
        desc="Dessa symboler är nära ett läge, men systemet vill se mer bekräftelse först."
      />
      <div className="live-watch-grid">
        {watching.map(r => (
          <div key={r.symbol} className="live-watch-card">
            <div className="live-watch-top">
              <span className="live-watch-sym">{r.symbol}</span>
              <TradeScoreBadge score={r.tradeScore} />
            </div>
            <div className="live-watch-meta">
              {r.preMoveContext?.preMoveWatchMode && (
                <span className="live-watch-chip live-chip-premove">Tidigt läge</span>
              )}
              {r.ruleMemory?.watchMode && (
                <span className="live-watch-chip live-chip-rule">Historiken stödjer</span>
              )}
              {r.confidence?.label === 'Bevaka' && (
                <span className="live-watch-chip live-chip-conf">Bevaka</span>
              )}
              {r.stateGraph?.currentState && r.stateGraph.currentState !== 'UNKNOWN' && (
                <span className="live-watch-chip" style={{ background: 'rgba(255,255,255,.07)' }}>
                  {r.stateGraph.currentState === 'COMPRESSION' ? '🗜 Komp' :
                   r.stateGraph.currentState === 'BREAKOUT' ? '🚀 Utbrott' :
                   r.stateGraph.currentState}
                </span>
              )}
            </div>
            {r.preMoveContext?.compressionStrength > 0 && (
              <div className="live-watch-bar-wrap">
                <div className="live-watch-bar" style={{ width: `${r.preMoveContext.compressionStrength}%` }} />
                <span className="live-watch-bar-label">Sammandragning {Math.round(r.preMoveContext.compressionStrength)}%</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}

// ── Market pulse strip ────────────────────────────────────────────────────────

const PERSONALITY_LABEL_SV = {
  panic_trend_day:          '🚨 Panikdag',
  fakeout_heavy_day:        '⚠️ Många falska rörelser',
  choppy_trap_market:       '🌀 Choppig marknad',
  exhaustion_environment:   '😴 Utmattad marknad',
  continuation_environment: '✅ Bra fortsättning',
  momentum_heavy_day:       '🚀 Bra fart',
  trend_day:                '📈 Trenddag',
  compression_day:          '🗜️ Komprimeringsdag',
  balanced_market:          '⚖️ Balanserad marknad',
  insufficient_data:        '📡 Väntar på data',
};

function MarketPulseStrip({ personality }) {
  if (!personality?.stocks && !personality?.crypto) return null;
  return (
    <div className="live-pulse-strip">
      {personality.stocks?.personalityLabel && (
        <div className="live-pulse-item">
          <span className="live-pulse-label">Aktier</span>
          <span className="live-pulse-val">
            {PERSONALITY_LABEL_SV[personality.stocks.personalityLabel] || personality.stocks.personalityLabel}
          </span>
          <span className="live-pulse-trust">Tilltro {personality.stocks.marketTrustScore}%</span>
        </div>
      )}
      {personality.crypto?.personalityLabel && (
        <div className="live-pulse-item">
          <span className="live-pulse-label">Krypto</span>
          <span className="live-pulse-val">
            {PERSONALITY_LABEL_SV[personality.crypto.personalityLabel] || personality.crypto.personalityLabel}
          </span>
          <span className="live-pulse-trust">Tilltro {personality.crypto.marketTrustScore}%</span>
      </div>
    )}
  </div>
);
}

function useSystemSnapshot() {
  const [health, setHealth] = useState(null);
  const [alerts, setAlerts] = useState(null);

  const fetchSnapshot = useCallback(async () => {
    const [h, a] = await Promise.all([
      fetch('/api/system/health').then(r => r.ok ? r.json() : null).catch(() => null),
      fetch('/api/alerts').then(r => r.ok ? r.json() : null).catch(() => null),
    ]);
    setHealth(h);
    setAlerts(a);
  }, []);

  useEffect(() => {
    fetchSnapshot();
    const t = setInterval(fetchSnapshot, 30_000);
    return () => clearInterval(t);
  }, [fetchSnapshot]);

  return { health, alerts, refresh: fetchSnapshot };
}

function PulseLine() {
  return (
    <svg className="pulse-line" viewBox="0 0 220 48" aria-hidden="true">
      <polyline points="0,28 35,28 48,18 58,35 72,12 88,28 125,28 138,22 150,31 165,16 184,28 220,28" />
    </svg>
  );
}

function PulseCard({ r }) {
  const status = simpleStatus(r);
  const score = scoreOf(r);
  return (
    <button className={`pulse-card pulse-${statusClass(status)}`} onClick={() => openTradingView(r.symbol, isCryptoSymbol(r.symbol) ? 'crypto' : 'stocks')}>
      <div className="pulse-card-top">
        <span className="pulse-symbol">{r.symbol}</span>
        <span className="pulse-status">{status}</span>
      </div>
      <PulseLine />
      <div className="pulse-card-bottom">
        <span>{score} poäng</span>
        <span>{directionSv(r)}</span>
      </div>
      <div className="pulse-why">{whyNow(r)}</div>
    </button>
  );
}

function MarketPulse({ rows }) {
  const pulseRows = rows
    .filter(r => r?.price && scoreOf(r) > 60)
    .sort((a, b) => scoreOf(b) - scoreOf(a))
    .slice(0, 8);

  return (
    <div className="live-command-section">
      <div className="live-section-head">
        <div>
          <div className="live-section-title">Marknadspuls</div>
          <div className="live-section-sub">Symboler över 60 poäng visas som aktiva pulser.</div>
        </div>
      </div>
      {pulseRows.length === 0 ? (
        <div className="live-calm-state">Marknaden är lugn just nu. Inga starka signaler över 60.</div>
      ) : (
        <div className="pulse-grid">
          {pulseRows.map(r => <PulseCard key={`${r.symbol}-${r.signal || ''}`} r={r} />)}
        </div>
      )}
    </div>
  );
}

function BestLiveCard({ r }) {
  const [open, setOpen] = useState(false);
  if (!r) {
    return (
      <div className="live-best-empty">
        <strong>Inget starkt läge just nu</strong>
        <span>Systemet väntar på bättre fart, tydligare riktning eller lägre risk.</span>
      </div>
    );
  }

  const score = scoreOf(r);
  const action = simpleStatus(r) === 'RISK' ? 'Vänta' : simpleStatus(r) === 'STARK' ? 'Bevaka' : 'Vänta';
  const hist = r?.momentumBacktestApplied
    ? 'Historiken stödjer fart ihop med flera tidsramar.'
    : 'Historiken ger inget extra stöd just nu.';

  return (
    <div className={`live-best-card live-best-${statusClass(simpleStatus(r))}`}>
      <div className="live-best-main">
        <div>
          <div className="live-kicker">Bästa läget just nu</div>
          <div className="live-best-symbol">{r.symbol}</div>
          <div className="live-best-dir">{directionSv(r)} · {score} poäng</div>
        </div>
        <div className="live-best-action">{action}</div>
      </div>
      <div className="live-best-grid">
        <div>
          <span>Varför systemet tittar på den</span>
          <strong>{whyNow(r)}</strong>
        </div>
        <div>
          <span>Risk</span>
          <strong>{riskSv(r)}</strong>
        </div>
        <div>
          <span>Vad historiken säger</span>
          <strong>{hist}</strong>
        </div>
        <div>
          <span>Vad du bör göra</span>
          <strong>{action}</strong>
        </div>
      </div>
      <div className="live-best-actions">
        <button className="btn btn-tv" onClick={() => openTradingView(r.symbol, isCryptoSymbol(r.symbol) ? 'crypto' : 'stocks')}>📈 Öppna TradingView</button>
        <button className="btn" onClick={() => setOpen(o => !o)}>{open ? 'Dölj tekniska detaljer' : 'Visa tekniska detaljer'}</button>
      </div>
      {open && <DecisionHeroCard r={r} tvLinkFn={tvLinkFor} />}
    </div>
  );
}

function Top5Simple({ rows }) {
  if (!rows.length) return null;
  return (
    <div className="live-command-section">
      <div className="live-section-title">Topp 5 just nu</div>
      <div className="live-simple-list">
        {rows.map((r, i) => (
          <div key={`${r.symbol}-${i}`} className="live-simple-row">
            <span className="live-simple-rank">#{i + 1}</span>
            <span className="live-simple-symbol">{r.symbol}</span>
            <span className={`live-simple-status ${statusClass(simpleStatus(r))}`}>{simpleStatus(r)}</span>
            <span className="live-simple-score">{scoreOf(r)} poäng</span>
            <span className="live-simple-reason">{whyNow(r)}</span>
          </div>
        ))}
      </div>
    </div>
  );
}

// ── Main page ─────────────────────────────────────────────────────────────────

export default function LivePage() {
  const { stocks, crypto, nasdaq, loading, lastFetch, refresh } = useMultiScan();
  const snapshot = useSystemSnapshot();
  const personality  = usePersonality();
  const { processResults } = useAlerts();
  const [learning, setLearning] = useState(null);
  const [showAdvanced, setShowAdvanced] = useState(false);

  useEffect(() => {
    fetch('/api/history/learning-summary')
      .then(r => r.ok ? r.json() : null)
      .then(j => { if (j?.summary) setLearning(j.summary); })
      .catch(() => {});
  }, []);

  // Feed alert engine
  useEffect(() => { if (stocks.length) processResults(stocks, 'stocks'); }, [stocks, processResults]);
  useEffect(() => { if (crypto.length) processResults(crypto, 'crypto'); }, [crypto, processResults]);
  useEffect(() => { if (nasdaq.length) processResults(nasdaq, 'nasdaq'); }, [nasdaq, processResults]);

  const allRaw = useMemo(() => [...stocks, ...nasdaq, ...crypto], [stocks, nasdaq, crypto]);
  const allEnriched = useMemo(() => enrichWithDecisions(allRaw, learning), [allRaw, learning]);

  const bestSignal = useMemo(() => getBestSignal(allEnriched), [allEnriched]);
  const top5       = useMemo(() => getTopN(allEnriched, 5), [allEnriched]);

  const hasData = allEnriched.some(r => r.price);
  const strongCount = allEnriched.filter(r => r.price && scoreOf(r) >= 60 && !r.autoFilter?.blocked).length;
  const watchCount = allEnriched.filter(r => r.price && !r.autoFilter?.blocked && (
    r.watchMode || r.momentumWatchMode || r.liquiditySweepWatchMode || (scoreOf(r) >= 35 && scoreOf(r) < 60)
  )).length;
  const alertCount = snapshot.alerts?.count ?? snapshot.alerts?.alerts?.length ?? 0;
  const systemStatus = snapshot.health?.overallStatus === 'HEALTHY'
    ? 'Systemet är ON'
    : snapshot.health?.overallStatus === 'CRITICAL'
      ? 'Kritiskt fel'
      : 'Varning';

  return (
    <div className="live-command-center">
      <div className="live-hero">
        <div className="live-hero-bg" />
        <div className="live-hero-content">
          <div>
            <div className="live-kicker">Kommandocenter</div>
            <h1>Live marknadspuls</h1>
            <p>Systemet bevakar aktier och krypto i bakgrunden och visar bara det viktigaste.</p>
          </div>
          <button className="live-refresh-btn" onClick={() => { refresh(); snapshot.refresh(); }}>
            {loading ? <span className="spinner" style={{ width: 12, height: 12 }} /> : '↻'} Uppdatera
          </button>
        </div>
        <div className="live-hero-stats">
          <div className="live-stat">
            <span>Systemstatus</span>
            <strong className={snapshot.health?.overallStatus === 'CRITICAL' ? 'risk' : snapshot.health?.overallStatus === 'HEALTHY' ? 'strong' : 'watch'}>
              {systemStatus}
            </strong>
          </div>
          <div className="live-stat">
            <span>Senaste scan</span>
            <strong>{lastFetch ? lastFetch.toLocaleTimeString('sv-SE', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '–'}</strong>
          </div>
          <div className="live-stat">
            <span>Starka signaler</span>
            <strong className="strong">{strongCount}</strong>
          </div>
          <div className="live-stat">
            <span>Bevaka-signaler</span>
            <strong className="watch">{watchCount}</strong>
          </div>
          <div className="live-stat">
            <span>Larm</span>
            <strong className={alertCount > 0 ? 'risk' : ''}>{alertCount}</strong>
          </div>
        </div>
      </div>

      {/* Market personality strip */}
      <MarketPulseStrip personality={personality} />

      {/* Risk warnings */}
      <RiskWarnings personality={personality} allResults={allEnriched} />

      {loading && !hasData && (
        <div className="empty"><span className="spinner" /> Hämtar live-data…</div>
      )}

      {hasData && (
        <>
          <MarketPulse rows={allEnriched} />

          <div className="live-command-section">
            <BestLiveCard r={bestSignal} />
          </div>

          <Top5Simple rows={top5} />

          <div className="live-advanced-wrap">
            <button className="live-advanced-toggle" onClick={() => setShowAdvanced(v => !v)}>
              {showAdvanced ? 'Dölj tekniska detaljer' : 'Visa tekniska detaljer'}
            </button>
            {showAdvanced && (
              <div className="live-advanced-body">
                <WatchModePanel allResults={allEnriched} />
              </div>
            )}
          </div>
        </>
      )}
    </div>
  );
}
