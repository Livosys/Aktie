{
  "name": "nasdaq-2m-scanner",
  "version": "1.0.0",
  "description": "2-minute Nasdaq Narrow State Scanner",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "npm --prefix client run build",
    "data:backfill": "node scripts/backfillAlpaca.js",
    "history:scan": "node scripts/runHistoricalScan.js",
    "history:analyze": "node scripts/analyzeSignalOutcomes.js",
    "memory:backfill": "node scripts/backfillSignalMemory.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "pg": "^8.12.0",
    "technicalindicators": "^3.1.0"
  }
}
