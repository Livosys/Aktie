ALPACA_API_KEY_ID=your_key_here
ALPACA_API_SECRET_KEY=your_secret_here
ALPACA_DATA_FEED=iex
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
PAPER_ALLOW_EMA=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true
# Motor v5 — historisk data
ALPACA_DATA_BASE_URL=https://data.alpaca.markets/v2
ALPACA_ENABLED=true
PORT=3001
NODE_ENV=production
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=your_strong_password_here
FEATURE_LOGGING_ENABLED=true

# ── Notification Engine v1 ────────────────────────────────────────────────────
NOTIFICATIONS_ENABLED=false
NOTIFICATION_PROVIDER=telegram
SIGNAL_NOTIFY_MIN_SCORE=70
SIGNAL_NOTIFY_COOLDOWN_MINUTES=15

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SIGNAL_WEBHOOK_URL=

# Prepared for future WhatsApp support. Not active in v1.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TARGET_PHONE=

# ── Auto-Machine v1 ────────────────────────────────────────────────────────────
# Kör aldrig pipelines automatiskt om inte detta sätts till true.
# DEFAULT: false — måste explicit aktiveras.
AUTO_MACHINE_ENABLED=false

# Hur ofta maskinen ska köras automatiskt (minuter). Minimum: 5.
AUTO_MACHINE_INTERVAL_MINUTES=60

# Hur många dagar bakåt i historiken som bearbetas per körning.
# Rekommenderat: 7 (balans mellan täckning och körtid).
AUTO_MACHINE_LOOKBACK_DAYS=7

# Kommaseparerade grupper att inkludera: stocks, crypto
# stocks = NVDA AMD TSLA AAPL MSFT AMZN META QQQ
# crypto = BTCUSDT ETHUSDT SOLUSDT
AUTO_MACHINE_GROUPS=stocks,crypto
